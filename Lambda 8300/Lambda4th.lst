0001+  2C81             ;###########################################################
0002+  2C81             ; Sound functions for Lambda 8300 BASIC for the Minstrel 4th
0003+  2C81             ; Dave Curran 2026-06-20
0004+  2C81             ;###########################################################
0005+  2C81             
0006+  2C81             ;##############################################################################
0007+  2C81             ; Play Note
0008+  2C81             ; E = note, defined as 32500Hz/E, so (0=256=>127Hz) to (1=>32.5KHz)
0009+  2C81             ; BC = duration, defined as BC/65ms, so (1=>15ms) to (0=65536=>1 second)
0010+  2C81             ; Two entry points, key beep, error and SOUND use PLAY_NOTE, MUSIC uses PLAY_NOTE_2
0011+  2C81             
0012+  2C81             PLAY_NOTE:
0013+  2C81             ; speaker on
0014+  2C81 AF              XOR A                               ; Clear A so save output (bit 5) stays low
0015+  2C82 D3 FE           OUT ($FE),A                         ; Speaker on    
0016+  2C84 53              LD D,E                              ; Load note period into D
0017+  2C85             
0018+  2C85             ; first loop, after speaker is on
0019+  2C85             PLAY_NOTE_2:
0020+  2C85 0B              DEC BC                              ; Count down duration
0021+  2C86 78              LD A,B                              ; Check if BC=0    
0022+  2C87 B1              OR C                                ; 
0023+  2C88 C8              RET Z                               ; If BC=0 exit here
0024+  2C89 15              DEC D                               ; Count down note    
0025+  2C8A 28 04           JR Z,_PLAY_NOTE_3                   ; Note countdown complete, speaker off
0026+  2C8C 00              NOP                                 ; Loop timing
0027+  2C8D 00              NOP                                 ;
0028+  2C8E 18 F5           JR PLAY_NOTE_2                      ; Loop until note or duration complete
0029+  2C90             
0030+  2C90             ; speaker off
0031+  2C90             _PLAY_NOTE_3:
0032+  2C90 DB FE           IN A,($FE)                          ; Speaker off
0033+  2C92 53              LD D,E                              ; Load note period into D
0034+  2C93             
0035+  2C93             ; second loop, with speaker off
0036+  2C93             _PLAY_NOTE_4:
0037+  2C93 0B              DEC BC                              ; Count down duration
0038+  2C94 78              LD A,B                              ; Check if BC=0    
0039+  2C95 B1              OR C                                ; 
0040+  2C96 C8              RET Z                               ; If BC=0 exit here
0041+  2C97 15              DEC D                               ; Count down note    
0042+  2C98 28 E7           JR Z,PLAY_NOTE                      ; Note countdown complete, speaker on
0043+  2C9A 00              NOP                                 ; Loop timing
0044+  2C9B 00              NOP                                 ;
0045+  2C9C 18 F5           JR _PLAY_NOTE_4                     ; Loop until note or duration complete
0046+  2C9E             
