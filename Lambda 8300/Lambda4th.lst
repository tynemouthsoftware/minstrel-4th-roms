0037   0000             .ORG $0000
0038   0000             ; START
0039   0000             START:
0040   0000 C3 40 2A        JP INIT_4TH                         ; Initialise the Minstrel 4th video RAM
0041   0003 00              NOP                                 ; clear original startcode
0042   0004 00              NOP                                 ;
0043   0005 00              NOP                                 ;
0044   0006             
0045   0038             .ORG $0038
0046   0038             ; --------------------------------
0047   0038             ; THE 'MASKABLE INTERRUPT' ROUTINE
0048   0038             ; --------------------------------
0049   0038             ; Called once every frame
0050   0038             
0051   0038             ; MASK-INT
0052   0038             ; Called once every frame either halted in fast mode or user code in slow
0053   0038 F5              PUSH AF                             ; store the accumulator andflags.
0054   0039              
0055   0039 3A 3B 40        LD A,($403B)                        ; getCDFLAG
0056   003C CB 7F           BIT 7,A                             ; check for slowmode
0057   003E             
0058   003E 20 02           JR NZ,RET_SLOW                      ; skip if SLOWmode
0059   0040              
0060   0040 F1              POP AF                              ; restore the accumulator andflags.
0061   0041 C9              RET                                 ; return for the next frame if FASTmode
0062   0042             
0063   0042             ; Slow mode interrupt - we have interrupted users code
0064   0042             RET_SLOW:
0065   0042              
0066   0042                 ; stackcontains:
0067   0042                 ; * User code returnaddress
0068   0042                 ; ** Previously pushedAF
0069   0042 C5              PUSH BC                             ; *** Remaining MainRegisters
0070   0043 D5              PUSH DE                             ;****
0071   0044 E5              PUSH HL                             ;*****
0072   0045              
0073   0045 C3 9D 02        JP L_029D                           ; ready for the start of the nextframe
0074   0048              
0075   0048 00              NOP                                 ; clear remains of originalcode
0076   0049             
0077   0066             .ORG $0066
0078   0066 ED 45           RETN                                ; no NMI on 4th
