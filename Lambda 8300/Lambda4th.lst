0546+  0226             
0547+  0226             ; This code converts a ZX81 program to the Lambda 8300
0548+  0226 2A 0C 40        LD HL,($400C)                       ; Location of the ZX81 DFILE (loaded with program)
0549+  0229 23              INC HL                              ; +1
0550+  022A 22 10 40        LD ($4010),HL                       ; Store this as
0551+  022D 21 7D 40        LD HL,DFILE                         ; Hard coded DFILE location
