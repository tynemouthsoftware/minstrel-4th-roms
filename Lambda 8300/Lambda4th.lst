0001   0000             ; Lamdba 8300 for Minstrel 4th
0002   0000             ; Dave Curran 2026-06-18
0003   0000             
0004   0000             ; TASM.EXE -t80 -fff -b Lamdba4th.asm Lamdba4th.bin
0005   0000             
0006   0000             ; Minstrel 4th Memory Map
0007   0000             ; =======================
0008   0000             
0009   0000             ; RAM
0010   0000             ; ---
0011   0000             ; 2000 - 23FF 1K Video RAM mirror (not used)
0012   0000             ; 2400 - 27FF 1K Video RAM 40x25 characters (read / write)
0013   0000             ; 2800 - 2BFF 1K Font RAM mirror (not used)
0014   0000             ; 2C00 - 2FFF 1K Font RAM 128 characters (write only)
0015   0000             
0016   0000             ; 3C00 - 3FFF 1K System RAM (not used)
0017   0000             
0018   0000             ; 4000 - FFFF 48K RAM (read / write)
0019   0000             
0020   0000             ; ROM
0021   0000             ; ---
0022   0000             ; 0000 - 1FFF 8K ROM
0023   0000             ; 2000 - 27FF 2K (not accessible)
0024   0000             ; 2800 - 3BFF 5K ROM
0025   0000             ; 3C00 - 3FFF 1K (not accessible)
0026   0000             
0027   0000             
0028   0000             .ORG $0000
0029   0000             .INCLUDE "Lambda8300.asm"
0001+  0000             ; Disassembly of the Lambda 8300 ROM
0002+  0000             ; Dave Curran 2026-06-12
0003+  0000             
0004+  0000             ; Latest version at:
0005+  0000             ; https://github.com/tynemouthsoftware/Lambda8300
0006+  0000             
0007+  0000             ; Where functions are identical to ZX81, only the function names are commented
0008+  0000             ; Refer to the ZX81 assembly listing by Geoff Wearmouth for further comments
0009+  0000             ; https://web.archive.org/web/20111004151617/http://www.wearmouth.demon.co.uk/zx81.htm
0010+  0000             
0011+  0000             ; assemble with TASM
0012+  0000             ; TASM.EXE -t80 -b Lambda8300.asm Lambda8300.bin
0013+  0000             
0014+  0000             ; Z80 @ 3.25MHz
0015+  0000             ; 8K of ROM
0016+  0000             ; 2K of RAM
0017+  0000             ; expandable to 32k of RAM
0018+  0000             
0019+  0000             ; Memory Map
0020+  0000             ; $0000-1FFF        - ROM
0021+  0000             ; $2000-3FFF        - Option ROM
0022+  0000             ; $4000     ERR.NR  - Current report code -1
0023+  0000             ; $4001     FLAGS   - Some flags
0024+  0000             ; $4002/03  ERR.SP  - Address of top of GOSUB stack
0025+  0000             ; $4004/05  RAMTOP  - Address of reserved area
0026+  0000             ; $4006     MODE    - Cursor mode
0027+  0000             ; $4007/08  PPC     - Line number being executed
0028+  0000             ; $4009     VERSN   - Version (from tape $00 = ZX81, $FF = Lambda)
0029+  0000             ; $400A/0B  NXTLIN  - Address of next line to be executed (ZX81 has E.PPC here)
0030+  0000             ; $400C/0D  PRGRM   - Start of user program = $4396 (ZX81 has DFILE here)
0031+  0000             ; $400E/0F  DF.CC   - Display file current character
0032+  0000             ; $4010/11  VARS    - Start of variable area
0033+  0000             ; $4012/13  DEST    - Address of variable being assigned
0034+  0000             ; $4014/15  E.LINE  - Address of edit line
0035+  0000             ; $4016/17  CH.ADD  - Next character to interpret
0036+  0000             ; $4018/19  X.PTR   - Addess of character before syntax error
0037+  0000             ; $401A/1B  STKBOT  - Address of calculator stack
0038+  0000             ; $401C/1D  STKEND  - End of calculator stack
0039+  0000             ; $401E     BREG    - Floating point B register
0040+  0000             ; $401F/20  MEM     - Address of calc memory area = MEMBOT
0041+  0000             ; $4021     TEMPO   - Setting of music tempo (was SPARE1)
0042+  0000             ; $4022     DF.SZ   - Size of editor part of screen
0043+  0000             ; $4023/24  S.TOP   - Line number at top of screen
0044+  0000             ; $4025/26  LAST.K  - Last keyboard scan
0045+  0000             ; $4027     DB.ST   - Keyboard debounce status
0046+  0000             ; $4028     MARGIN  - Number of lines in margin
0047+  0000             ; $4029/2A  E.PPC   - Line number of line with cursor (ZX81 has NXTLIN here)
0048+  0000             ; $402B/2C  OLDPPC  - Address of line where CONT jumps
0049+  0000             ; $402D     FLAGX   - Some more flags
0050+  0000             ; $402E/F   STRLEN  - String length
0051+  0000             ; $4030/31  T.ADDR  - Next item in syntax table
0052+  0000             ; $4032/33  SEED    - Seed for RND
0053+  0000             ; $4034/35  FRAMES  - Frame counter
0054+  0000             ; $4035/37  COORDS  - Last point plotted (to add for DRAW?)
0055+  0000             ; $4038     PR.CC   - Address of LPRINT position
0056+  0000             ; $4039/3A  S.POSN  - Current PRINT position
0057+  0000             ; $403B     CDFLAG  - Compute Display Flags for FAST/SLOW mode (Bit 7 = 1 for SLOW, Bit 6 = 1 to request SLOW mode)
0058+  0000             ; $403C-5C  PRBUFF  - Printer buffer
0059+  0000             ; $405D-7A  MEMBOT  - Calculator memory
0060+  0000             ; $407B-7C  BLINK   - Cursor blink
0061+  0000             ; $407D-$4395       - Display file
0062+  0000             ; $4396-RAMTOP      - User Program memory
0063+  0000             
0064+  0000             ; no DFILE variable - Location of display file, that is hard coded at $407D
0065+  0000             DFILE .EQU $407D
0066+  0000             
0067+  0000             .ORG $0000
0068+  0000             
0069+  0000             ; -----------
0070+  0000             ; THE 'START'
0071+  0000             ; -----------
0072+  0000             
0073+  0000             ; START
0074+  0000             L_0000:
0075+  0000 D3 FD           OUT ($FD),A                         ; turn off NMI
0076+  0002 3E BF           LD A,$BF
0077+  0004 DB FE           IN A,($FE)                          ; keyboard read (hold down key for ROM at $2000?)
0078+  0006 18 1D           JR L_0025                           ; Jump to START-3 via START-2
0079+  0008             
0080+  0008             ; -------------------
0081+  0008             ; THE 'ERROR' RESTART
0082+  0008             ; -------------------
0083+  0008             
0084+  0008             ; ERROR-1
0085+  0008             L_0008:
0086+  0008 2A 16 40        LD HL,($4016)                       ; CH.ADD - Address of next character to interpret
0087+  000B 22 18 40        LD ($4018),HL                       ; X.PTR - Address of character before error
0088+  000E 18 47           JR L_0057                           ;
0089+  0010             
0090+  0010             ; -------------------------------
0091+  0010             ; THE 'PRINT A CHARACTER' RESTART
0092+  0010             ; -------------------------------
0093+  0010             
0094+  0010             ; PRINT-A
0095+  0010             L_0010:
0096+  0010 A7              AND A
0097+  0011             L_0011:
0098+  0011 C2 92 09        JP NZ,L_0992
0099+  0014 C3 96 09        JP L_0996
0100+  0017             
0101+  0017 FF              .BYTE $FF                           ; unused
0102+  0018             
0103+  0018             ; ---------------------------------
0104+  0018             ; THE 'COLLECT A CHARACTER' RESTART
0105+  0018             ; ---------------------------------
0106+  0018             
0107+  0018             ; GET-CHAR
0108+  0018             L_0018:
0109+  0018 2A 16 40        LD HL,($4016)
0110+  001B 7E              LD A,(HL)
0111+  001C             L_001C:
0112+  001C A7              AND A
0113+  001D C0              RET NZ
0114+  001E 00              NOP
0115+  001F 00              NOP
0116+  0020             
0117+  0020             ; ------------------------------------
0118+  0020             ; THE 'COLLECT NEXT CHARACTER' RESTART
0119+  0020             ; ------------------------------------
0120+  0020             
0121+  0020             ; NEXT-CHAR
0122+  0020             L_0020:
0123+  0020 CD 4A 00        CALL SUB_004A
0124+  0023 18 F7           JR L_001C
0125+  0025             
0126+  0025             ; start continued
0127+  0025             
0128+  0025             ; START-2
0129+  0025             L_0025:
0130+  0025 C3 6E 04        JP L_046E
0131+  0028             
0132+  0028             ; ---------------------------------------
0133+  0028             ; THE 'FLOATING POINT CALCULATOR' RESTART
0134+  0028             ; ---------------------------------------
0135+  0028             
0136+  0028             ; FP-CALC
0137+  0028             L_0028:
0138+  0028 C3 94 1B        JP L_1B94
0139+  002B             
0140+  002B             ; end-calc
0141+  002B             SUB_002B:
0142+  002B F1              POP AF
0143+  002C D9              EXX
0144+  002D E3              EX (SP),HL
0145+  002E D9              EXX
0146+  002F C9              RET
0147+  0030             
0148+  0030             ; -----------------------------
0149+  0030             ; THE 'MAKE BC SPACES'  RESTART
0150+  0030             ; -----------------------------
0151+  0030             
0152+  0030             ; BC-SPACES
0153+  0030             L_0030:
0154+  0030 C5              PUSH BC
0155+  0031 2A 14 40        LD HL,($4014)
0156+  0034 E5              PUSH HL
0157+  0035 C3 7D 16        JP L_167D
0158+  0038             
0159+  0038             ; -----------------------
0160+  0038             ; THE 'INTERRUPT' RESTART
0161+  0038             ; -----------------------
0162+  0038             
0163+  0038             ; INTERRUPT
0164+  0038             L_0038:
0165+  0038 0D              DEC C
0166+  0039 20 0A           JR NZ,L_0045
0167+  003B E1              POP HL
0168+  003C 05              DEC B
0169+  003D C8              RET Z
0170+  003E C8              RET Z                               ; extra delay? not in ZX81
0171+  003F 0E 08           LD C,$08                            ; faster than SET 3,C (but is that a good thing here?)
0172+  0041             
0173+  0041             ; WAIT-INT
0174+  0041             L_0041:
0175+  0041 ED 4F           LD R,A
0176+  0043 FB              EI
0177+  0044 E9              JP (HL)                             ; jump into display file mirror
0178+  0045             
0179+  0045             ; SCAN-LINE
0180+  0045             L_0045:
0181+  0045 D1              POP DE
0182+  0046 00              NOP                                 ; different timing to ZX81
0183+  0047 18 F8           JR L_0041
0184+  0049             
0185+  0049 00              .BYTE $00                           ; unused (which moved $004A-$0065 1 byte away from ZX81)
0186+  004A             
0187+  004A             ; ---------------------------------
0188+  004A             ; THE 'INCREMENT CH-ADD' SUBROUTINE
0189+  004A             ; ---------------------------------
0190+  004A             
0191+  004A             ; CH-ADD+1
0192+  004A             SUB_004A:
0193+  004A 2A 16 40        LD HL,($4016)
0194+  004D             
0195+  004D             ; TEMP-PTR1
0196+  004D             L_004D:
0197+  004D 23              INC HL
0198+  004E             
0199+  004E             ; TEMP-PTR2
0200+  004E             SUB_004E:
0201+  004E 22 16 40        LD ($4016),HL
0202+  0051 7E              LD A,(HL)
0203+  0052 FE 7F           CP $7F
0204+  0054 C0              RET NZ
0205+  0055 18 F6           JR L_004D
0206+  0057             
0207+  0057             ; --------------------
0208+  0057             ; THE 'ERROR-2' BRANCH
0209+  0057             ; --------------------
0210+  0057             
0211+  0057             ; ERROR-2
0212+  0057             L_0057:
0213+  0057 E1              POP HL                              ; get error code
0214+  0058 6E              LD L,(HL)                           ; extract error byte
0215+  0059             
0216+  0059             ; ERROR-3
0217+  0059             L_0059:
0218+  0059 FD 75 00        LD (IY+$00),L                       ; set ERR_NR, system error number
0219+  005C ED 7B 02 40     LD SP,($4002)                       ; reset stack pointer to top of GOSUB stack
0220+  0060 CD 85 02        CALL SUB_0285                       ; SLOW mode
0221+  0063 C3 B4 16        JP L_16B4                           ; exit via SET_MIN to clear calculator stack
0222+  0066             
0223+  0066             ; ------------------------------------
0224+  0066             ; THE 'NON MASKABLE INTERRUPT' ROUTINE
0225+  0066             ; ------------------------------------
0226+  0066             
0227+  0066             ; NMI
0228+  0066             L_0066:
0229+  0066 08              EX AF,AF'                           ; NMI uses the alternate A&F
0230+  0067 3C              INC A                               ; Incrememnt line count
0231+  0068 CA 6E 00        JP Z,L_006E                         ; Jump if line count has reached 0
0232+  006B 00              NOP                                 ; NMI test removed (ROM will not run on ZX80 hardware)
0233+  006C             
0234+  006C             ; NMI-RET
0235+  006C 08              EX AF,AF'                           ; Return to normal A&F
0236+  006D C9              RET                                 ; Return to user code
0237+  006E             
0238+  006E             ; NMI-CONT
0239+  006E             L_006E:
0240+  006E 08              EX AF,AF'                           ; Return to normal A&F
0241+  006F F5              PUSH AF                             ; Save the main registers
0242+  0070 C5              PUSH BC                             ;
0243+  0071 D5              PUSH DE                             ;
0244+  0072 E5              PUSH HL                             ;
0245+  0073 21 7D C0        LD HL,$407D + $8000                 ; Set HL to fixed DFILE mirror location (not ($400C) with bit 7 set)
0246+  0076 76              HALT                                ; sync with NMI
0247+  0077             
0248+  0077 D3 FD           OUT ($FD),A                         ; stop the NMI generator
0249+  0079 DD E9           JP (IX)                             ; forward to R-IX-1 (after top) or R-IX-2
0250+  007B             
0251+  007B             
0252+  007B             ; ****************
0253+  007B             ; ** KEY TABLES **
0254+  007B             ; ****************
0255+  007B             
0256+  007B             ; -------------------------------
0257+  007B             ; THE 'UNSHIFTED' CHARACTER CODES
0258+  007B             ; -------------------------------
0259+  007B             
0260+  007B             ; K-UNSHIFT
0261+  007B             L_007B:
0262+  007B             
0263+  007B 3F              .BYTE    $3F                        ; Z
0264+  007C 3D              .BYTE    $3D                        ; X
0265+  007D 28              .BYTE    $28                        ; C
0266+  007E 3B              .BYTE    $3B                        ; V
0267+  007F             
0268+  007F 26              .BYTE    $26                        ; A
0269+  0080 38              .BYTE    $38                        ; S
0270+  0081 29              .BYTE    $29                        ; D
0271+  0082 2B              .BYTE    $2B                        ; F
0272+  0083 2C              .BYTE    $2C                        ; G
0273+  0084             
0274+  0084 36              .BYTE    $36                        ; Q
0275+  0085 3C              .BYTE    $3C                        ; W
0276+  0086 2A              .BYTE    $2A                        ; E
0277+  0087 37              .BYTE    $37                        ; R
0278+  0088 39              .BYTE    $39                        ; T
0279+  0089             
0280+  0089 1D              .BYTE    $1D                        ; 1
0281+  008A 1E              .BYTE    $1E                        ; 2
0282+  008B 1F              .BYTE    $1F                        ; 3
0283+  008C 20              .BYTE    $20                        ; 4
0284+  008D 21              .BYTE    $21                        ; 5
0285+  008E             
0286+  008E 1C              .BYTE    $1C                        ; 0
0287+  008F 25              .BYTE    $25                        ; 9
0288+  0090 24              .BYTE    $24                        ; 8
0289+  0091 23              .BYTE    $23                        ; 7
0290+  0092 22              .BYTE    $22                        ; 6
0291+  0093             
0292+  0093 35              .BYTE    $35                        ; P
0293+  0094 34              .BYTE    $34                        ; O
0294+  0095 2E              .BYTE    $2E                        ; I
0295+  0096 3A              .BYTE    $3A                        ; U
0296+  0097 3E              .BYTE    $3E                        ; Y
0297+  0098             
0298+  0098 76              .BYTE    $76                        ; NEWLINE
0299+  0099 31              .BYTE    $31                        ; L
0300+  009A 30              .BYTE    $30                        ; K
0301+  009B 2F              .BYTE    $2F                        ; J
0302+  009C 2D              .BYTE    $2D                        ; H
0303+  009D             
0304+  009D 00              .BYTE    $00                        ; SPACE
0305+  009E 1B              .BYTE    $1B                        ; .
0306+  009F 32              .BYTE    $32                        ; M
0307+  00A0 33              .BYTE    $33                        ; N
0308+  00A1 27              .BYTE    $27                        ; B
0309+  00A2             
0310+  00A2             ; -----------------------------
0311+  00A2             ; THE 'SHIFTED' CHARACTER CODES
0312+  00A2             ; -----------------------------
0313+  00A2             
0314+  00A2             ; K-SHIFT
0315+  00A2             L_00A2:
0316+  00A2 F5              .BYTE    $F5                        ; Shift + Z = PRINT
0317+  00A3 7A              .BYTE    $7A                        ; Shift + X = Line no
0318+  00A4 70              .BYTE    $70                        ; Shift + C = cursor-up
0319+  00A5 71              .BYTE    $71                        ; Shift + V = cursor-down
0320+  00A6             
0321+  00A6 C6              .BYTE    $C6                        ; Shift + A = ASN
0322+  00A7 C7              .BYTE    $C7                        ; Shift + S = ACS
0323+  00A8 C8              .BYTE    $C8                        ; Shift + D = ATN
0324+  00A9 CA              .BYTE    $CA                        ; Shift + F = EXP
0325+  00AA CE              .BYTE    $CE                        ; Shift + G = ABS
0326+  00AB             
0327+  00AB C3              .BYTE    $C3                        ; Shift + Q = SIN
0328+  00AC C4              .BYTE    $C4                        ; Shift + W = COS
0329+  00AD C5              .BYTE    $C5                        ; Shift + E = TAN
0330+  00AE C9              .BYTE    $C9                        ; Shift + R = LOG
0331+  00AF CD              .BYTE    $CD                        ; Shift + T = SGN
0332+  00B0             
0333+  00B0 0F              .BYTE    $0F                        ; Shift + 1 = ?
0334+  00B1 0C              .BYTE    $0C                        ; Shift + 2 = £
0335+  00B2 0E              .BYTE    $0E                        ; Shift + 3 = :
0336+  00B3 0D              .BYTE    $0D                        ; Shift + 4 = $
0337+  00B4 0B              .BYTE    $0B                        ; Shift + 5 = "
0338+  00B5             
0339+  00B5 14              .BYTE    $14                        ; Shift + 0 = =
0340+  00B6 11              .BYTE    $11                        ; Shift + 9 = )
0341+  00B7 10              .BYTE    $10                        ; Shift + 8 = (
0342+  00B8 1A              .BYTE    $1A                        ; Shift + 7 = ,
0343+  00B9 19              .BYTE    $19                        ; SHIFT + 6 =                           ;
0344+  00BA             
0345+  00BA 12              .BYTE    $12                        ; Shift + P = >
0346+  00BB 13              .BYTE    $13                        ; Shift + O = <
0347+  00BC 45              .BYTE    $45                        ; Shift + I = PI
0348+  00BD 43              .BYTE    $43                        ; Shift + U = RND
0349+  00BE CC              .BYTE    $CC                        ; Shift + Y = SQR
0350+  00BF             
0351+  00BF 74              .BYTE    $74                        ; Shift + N/L = GRAPHICS
0352+  00C0 15              .BYTE    $15                        ; Shift + L = +
0353+  00C1 16              .BYTE    $16                        ; Shift + K = -
0354+  00C2 17              .BYTE    $17                        ; Shift + J = *
0355+  00C3 18              .BYTE    $18                        ; Shift + H = /
0356+  00C4             
0357+  00C4 79              .BYTE    $79                        ; Shift + SPACE = FUNCTION
0358+  00C5 77              .BYTE    $77                        ; Shift + . = RUBOUT
0359+  00C6 75              .BYTE    $75                        ; Shift + M = EDIT
0360+  00C7 73              .BYTE    $73                        ; Shift + N = cursor-right
0361+  00C8 72              .BYTE    $72                        ; Shift + B = cursor-left
0362+  00C9             
0363+  00C9             
0364+  00C9             ; -----------------------------
0365+  00C9             ; THE 'GRAPHIC' CHARACTER CODES
0366+  00C9             ; -----------------------------
0367+  00C9             
0368+  00C9             ; K-GRAPH
0369+  00C9             ; 00c9
0370+  00C9 83              .BYTE    $83                        ; Graphics + Z = graphic
0371+  00CA 03              .BYTE    $03                        ; Graphics + X = graphic
0372+  00CB 05              .BYTE    $05                        ; Graphics + C = graphic
0373+  00CC 85              .BYTE    $85                        ; Graphics + V = graphic
0374+  00CD             
0375+  00CD 08              .BYTE    $08                        ; Graphics + A = graphic
0376+  00CE 0A              .BYTE    $0A                        ; Graphics + S = graphic
0377+  00CF 09              .BYTE    $09                        ; Graphics + D = graphic
0378+  00D0 8A              .BYTE    $8A                        ; Graphics + F = graphic
0379+  00D1 89              .BYTE    $89                        ; Graphics + G = graphic
0380+  00D2             
0381+  00D2 01              .BYTE    $01                        ; Graphics + Q = graphic
0382+  00D3 02              .BYTE    $02                        ; Graphics + W = graphic
0383+  00D4 04              .BYTE    $04                        ; Graphics + E = graphic
0384+  00D5 87              .BYTE    $87                        ; Graphics + R = graphic
0385+  00D6 81              .BYTE    $81                        ; Graphics + T = graphic
0386+  00D7             
0387+  00D7 8F              .BYTE    $8F                        ; Graphics + 1 = graphic
0388+  00D8 8C              .BYTE    $8C                        ; Graphics + 2 = graphic
0389+  00D9 8E              .BYTE    $8E                        ; Graphics + 3 = graphic
0390+  00DA 8D              .BYTE    $8D                        ; Graphics + 4 = inverse $
0391+  00DB 8B              .BYTE    $8B                        ; Graphics + 5 = inverse "
0392+  00DC             
0393+  00DC 94              .BYTE    $94                        ; Graphics + 0 = inverse =
0394+  00DD 91              .BYTE    $91                        ; Graphics + 9 = inverse )
0395+  00DE 90              .BYTE    $90                        ; Graphics + 8 = inverse (
0396+  00DF 9A              .BYTE    $9A                        ; Graphics + 7 = inverse ,
0397+  00E0 99              .BYTE    $99                        ; GRAPHICS + 6 = INVERSE                           ;
0398+  00E1             
0399+  00E1 92              .BYTE    $92                        ; Graphics + P = inverse >
0400+  00E2 93              .BYTE    $93                        ; Graphics + O = inverse <
0401+  00E3 07              .BYTE    $07                        ; Graphics + I = graphic
0402+  00E4 84              .BYTE    $84                        ; Graphics + U = graphic
0403+  00E5 82              .BYTE    $82                        ; Graphics + Y = graphic
0404+  00E6             
0405+  00E6 78              .BYTE    $78                        ; Graphics + N/L = KL
0406+  00E7 95              .BYTE    $95                        ; Graphics + L = inverse +
0407+  00E8 96              .BYTE    $96                        ; Graphics + K = inverse -
0408+  00E9 97              .BYTE    $97                        ; Graphics + J = inverse *
0409+  00EA 98              .BYTE    $98                        ; Graphics + H = inverse /
0410+  00EB             
0411+  00EB 78              .BYTE    $78                        ; Graphics + SPACE =
0412+  00EC 77              .BYTE    $77                        ; Graphics + . = RUBOUT
0413+  00ED 78              .BYTE    $78                        ; Graphics + M = KL
0414+  00EE 86              .BYTE    $86                        ; Graphics + N = graphic
0415+  00EF 06              .BYTE    $06                        ; Graphics + B = graphic
0416+  00F0             
0417+  00F0             ; ------------------
0418+  00F0             ; THE 'TOKEN' TABLES
0419+  00F0             ; ------------------
0420+  00F0             
0421+  00F0             ; TOKENS
0422+  00F0             L_00F0:
0423+  00F0 9B              .BYTE   $1B+$80                     ; '.' + $80 ?
0424+  00F1             L_00F1:
0425+  00F1 28 34 29 AA     .BYTE   $28,$34,$29,$2A+$80         ; CODE
0426+  00F5 3B 26 B1        .BYTE   $3B,$26,$31+$80             ; VAL
0427+  00F8 31 2A B3        .BYTE   $31,$2A,$33+$80             ; LEN
0428+  00FB 38 2E B3        .BYTE   $38,$2E,$33+$80             ; SIN
0429+  00FE 28 34 B8        .BYTE   $28,$34,$38+$80             ; COS
0430+  0101 39 26 B3        .BYTE   $39,$26,$33+$80             ; TAN
0431+  0104 26 38 B3        .BYTE   $26,$38,$33+$80             ; ASN
0432+  0107 26 28 B8        .BYTE   $26,$28,$38+$80             ; ACS
0433+  010A 26 39 B3        .BYTE   $26,$39,$33+$80             ; ATN
0434+  010D 31 34 AC        .BYTE   $31,$34,$2C+$80             ; LOG
0435+  0110 2A 3D B5        .BYTE   $2A,$3D,$35+$80             ; EXP
