0537+  021E EB              EX DE,HL                            ; Restore destination
0538+  021F D0              RET NC                              ; return if the end has not been reached
0539+  0220 E1              POP HL                              ; drop the return address and continue
0540+  0221             ; ZX81 drops to SLOW here
0541+  0221             
0542+  0221             ; LOAD/SAVE-COMPLETE
0543+  0221             L_0221:
0544+  0221 FD 34 09        INC (IY+$09)                        ; increment version (from tape Lambda = $FF, ZX81 = $00. normal Lambda = $00, ZX81 = $01)
