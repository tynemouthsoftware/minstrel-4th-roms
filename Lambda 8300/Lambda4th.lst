0001+  2A40             ;##############################################################################
0002+  2A40             ; Init and display functions for Lambda 8300 BASIC for the Minstrel 4th
0003+  2A40             ; Dave Curran 2026-06-18
0004+  2A40             ;##############################################################################
0005+  2A40             
0006+  2A40             ;##############################################################################
0007+  2A40             ; Initialisation code for the 4th
0008+  2A40             ;
0009+  2A40             ; Clear the video RAM and load the Lambda 8300 font into the font RAM
0010+  2A40             ; Display a banner, which will remain until first actual CLS
0011+  2A40             ;
0012+  2A40             
0013+  2A40             INIT_4TH:
0014+  2A40             
0015+  2A40             ; setup UDG $7F as all ones, so the inverted $FF appears like a space
0016+  2A40 06 FF           LD B, $FF                           ; set character bitmap in B
0017+  2A42 48              LD C, B                             ; and C
0018+  2A43 ED 43 F8 2F     LD ($2FF8),BC                       ; write 8 rows, 2 at a time
0019+  2A47 ED 43 FA 2F     LD ($2FFA),BC                       ;
0020+  2A4B ED 43 FC 2F     LD ($2FFC),BC                       ;
0021+  2A4F ED 43 FE 2F     LD ($2FFE),BC                       ;
0022+  2A53             
0023+  2A53             ; now fill the screen with $ff, which should clear it
0024+  2A53             INITIAL_SCREEN_CLEAR:
0025+  2A53 21 00 24        LD HL, $2400                        ; start of character video RAM
0026+  2A56 11 01 24        LD DE, $2401                        ; the next byte
0027+  2A59 01 FF 02        LD BC, $02FF                        ; number of bytes to clear - 1
0028+  2A5C 36 FF           LD (HL), $FF                        ; set the first byte
0029+  2A5E ED B0           LDIR                                ; clear all the rest
0030+  2A60             
0031+  2A60 AF              XOR A                               ; A = 0
0032+  2A61 12              LD (DE), A                          ; make $2700 (first location after screen) zero.
0033+  2A62 13              INC DE                              ; make $2701 zero, to indicate initial boot
0034+  2A63 12              LD (DE), A                          ; 
0035+  2A64             
0036+  2A64             ; copy the 8300 font into the first half of font RAM - should be no conflicts, none of these characters are on screen
0037+  2A64             COPYFONT: 
0038+  2A64 11 00 2C        LD DE, $2C00                        ; Destination is write only font RAM
0039+  2A67 21 00 28        LD HL, FONT                         ; Lambda 8300 font in ROM
0040+  2A6A 01 00 02        LD BC, $0200                        ; There are 64 bit-mapped 8x8 characters
0041+  2A6D ED B0           LDIR                                ; Copy font from ROM to RAM
0042+  2A6F             
0043+  2A6F             ; copy a banner message to the top of the screen
0044+  2A6F             BANNER:
0045+  2A6F 11 00 24        LD DE, $2400                        ; top of 4TH video RAM 
0046+  2A72 21 D6 2C        LD HL, BANNER_TEXT                  ; banner message
0047+  2A75 01 20 00        LD BC, $20                          ; 32 characters
0048+  2A78 ED B0           LDIR
0049+  2A7A             
0050+  2A7A             ; the screen at this point has the banner and the rest are $FF characters
0051+  2A7A             ; when the Lambda 8300 init is complete, the first display cycle will overwrite this
0052+  2A7A             ; also with the banner, but all the rest of the characters will be $00 as normal
0053+  2A7A             ; apart from the inverse K on the edit line
0054+  2A7A             
0055+  2A7A             ; resume where the initial reset function
0056+  2A7A             ON_TO_RAM_CHECK:
0057+  2A7A 01 FF FF        LD BC,$FFFF                         ; top of possible RAM.
0058+  2A7D C3 89 04        JP L_0489                           ; on to RAM-CHECK.
0059+  2A80             
0060+  2A80             
0061+  2A80             ;###########################################################
0062+  2A80             ; Called during clear after init and also after loading
0063+  2A80             ; Check if this is init and display the banner
0064+  2A80             SHOW_BANNER:
0065+  2A80 CD A5 16        CALL SUB_16A5                       ; CURSOR-IN, set cursor on edit line
0066+  2A83 CD D0 0B        CALL SUB_0BD0                       ; CLS function
0067+  2A86             
0068+  2A86 3A 01 27        LD A, ($2701)                       ; Check if this is the initial boot
0069+  2A89 A7              AND A                               ; Test
0070+  2A8A C2 9D 2A        JP NZ, BANNER_DONE                  ; skip if not
0071+  2A8D             
0072+  2A8D 11 7D 40        LD DE, $407D                        ; set DFILE as the destination
0073+  2A90 13              INC DE                              ; step over the first NL
0074+  2A91              
0075+  2A91 21 D6 2C        LD HL, BANNER_TEXT                  ; Banner message
0076+  2A94 01 20 00        LD BC, $20                          ; 32 characters
0077+  2A97 ED B0           LDIR                                ; copy banner
0078+  2A99             
0079+  2A99 21 01 27        LD HL, $2701                        ; set $2701 to 1 so banner will not be redrawn
0080+  2A9C 34              INC (HL)                            ;
0081+  2A9D             
0082+  2A9D             BANNER_DONE:
0083+  2A9D CD 85 02        CALL SUB_0285                       ; SLOW-FAST to set SLOW mode
0084+  2AA0 C3 02 05        JP L_04FF+3                         ; jump back in just after the CLS
0085+  2AA3             
0086+  2AA3             ;##########################################################
0087+  2AA3             ; Copy the Lambda 8300 display file to the 4th screen RAM
0088+  2AA3             
0089+  2AA3             ; Optimised for fully expanded fixed locate DFILE
0090+  2AA3             
0091+  2AA3             DISPLAY_ROUTINE:
0092+  2AA3 21 7D 40        LD HL,$407D                         ; Set HL to the Display File location
0093+  2AA6 11 00 24        LD DE,$2400                         ; Set DE to the Minstrel 4th screen RAM 
0094+  2AA9 3E 18           LD A,$18                            ; 24 lines
0095+  2AAB             
0096+  2AAB             COPY_LINE:
0097+  2AAB 23              INC HL                              ; skip the HALT / newline
0098+  2AAC 01 20 00        LD BC,$0020                         ; 32 characters per line
0099+  2AAF ED B0           LDIR                                ; copy line
0100+  2AB1             
0101+  2AB1 3D              DEC A                               ; finished?
0102+  2AB2 20 F7           JR NZ,COPY_LINE                     ; no, more lines
0103+  2AB4             
0104+  2AB4              
0105+  2AB4             
0106+  2AB4             ; waste time to be 100% Lambda 8300 speed
0107+  2AB4             ; yes, I did just keep adding and removing delays until it matched.
0108+  2AB4             ; LD B, $E3                             ; initial delay count
0109+  2AB4             
0110+  2AB4             ; WASTE_TIME:
0111+  2AB4             ; NOP
0112+  2AB4             ; NOP
0113+  2AB4             ; NOP
0114+  2AB4             ; DJNZ WASTE_TIME 
0115+  2AB4             
0116+  2AB4             ; end of frame
0117+  2AB4              
0118+  2AB4 3A 3B 40        LD A,($403B)                        ; get CDFLAG - DO NOT USE IY HERE
0119+  2AB7 CB 7F           BIT 7,A                             ; check for slow mode
0120+  2AB9             
0121+  2AB9 C2 BF 2A        JP NZ, END_SLOW                     ; fast mode?
0122+  2ABC             
0123+  2ABC             ; End the frame in fast mode. 
0124+  2ABC             ; Waste time until for the interrupt then go onto the next frame
0125+  2ABC             END_FAST:
0126+  2ABC FB              EI                                  ; enable interrupts.
0127+  2ABD 76              HALT                                ; halt and wait for the next interrupt
0128+  2ABE              
0129+  2ABE C9              RET                                 ; onto DISPLAY-1, start of the next frame
0130+  2ABF             
0131+  2ABF             ; End the frame in slow mode.
0132+  2ABF             ; return to users code until interrupted by the IRQ
0133+  2ABF             END_SLOW
0134+  2ABF E1              POP HL                              ; Throw away the call address 
0135+  2AC0             
0136+  2AC0 E1              POP HL                              ; ****
0137+  2AC1 D1              POP DE                              ; ***
0138+  2AC2 C1              POP BC                              ; **
0139+  2AC3 F1              POP AF                              ; * Restore Main Registers
0140+  2AC4             
0141+  2AC4 FB              EI                                  ; enable frame interrupts
0142+  2AC5             
0143+  2AC5 C9              RET                                 ; return - end of interrupt. Return is to 
0144+  2AC6                                                     ; user's program - BASIC or machine code.
0145+  2AC6                                                     ; which will be interrupted by every NMI.
0146+  2AC6             
0147+  2AC6             
0148+  2AC6             
0149+  2AC6             ;###########################################################
0150+  2AC6             ; clear the screen to indicate "fast" mode where the ZX80/1 
0151+  2AC6             ; would have stopped producing a television picture
0152+  2AC6             
0153+  2AC6             NEW_FAST:
0154+  2AC6 CD 70 03        CALL SUB_0370                       ; routine SET-FAST
0155+  2AC9 FD CB 3B B6     RES 6,(IY+$3B)                      ; Clear request CDFLAG
0156+  2ACD             
0157+  2ACD E5              PUSH HL
0158+  2ACE D5              PUSH DE
0159+  2ACF C5              PUSH BC
0160+  2AD0             
0161+  2AD0 21 00 24        LD HL, $2400                        ; start of video RAM
0162+  2AD3 11 01 24        LD DE, $2401                        ; the next byte
0163+  2AD6 01 FF 02        LD BC, $02FF                        ; number of bytes to clear -1
0164+  2AD9 AF              XOR A                               ; clear A
0165+  2ADA 77              LD (HL), A                          ; clear the first byte
0166+  2ADB ED B0           LDIR                                ; set all the rest to match
0167+  2ADD             
0168+  2ADD C1              POP BC
0169+  2ADE D1              POP DE
0170+  2ADF E1              POP HL
0171+  2AE0             
0172+  2AE0 C9              RET
0173+  2AE1             
0174+  2AE1             ;###################################################################
0175+  2AE1             ; The load routine detects if the program originated from a ZX81. 
0176+  2AE1             ; If it did, it patches it up to run.
0177+  2AE1             ; Extra routine to patch the font to reinstate 6 altered characters
0178+  2AE1             ; (also overwrites two unchanged characters to save having two loops)
0179+  2AE1             PATCH_FONT: 
0180+  2AE1 11 40 2C        LD DE, $2C40                        ; Destination is write only font RAM
0181+  2AE4 21 00 2A        LD HL, ZX81_FONT                    ; zx81 font characters $08-$0F in ROM
0182+  2AE7 01 40 00        LD BC, $0040                        ; There are 8 bit-mapped 8x8 characters
0183+  2AEA ED B0           LDIR                                ; Copy font from ROM to RAM
0184+  2AEC             
0185+  2AEC                                                     ; this is the line of code we replaced
0186+  2AEC 2A 0C 40        LD HL,($400C)                       ; Location of the ZX81 DFILE (loaded with program)
0187+  2AEF             
0188+  2AEF C9              RET                                 ; back to LOAD/SAVE
0189+  2AF0             
0190+  2AF0             ;###################################################################
0191+  2AF0             ; A variation of the ZX81 function in the second half of COPY_NEXT
0192+  2AF0             ; Read character data from the font in ROM ($2800-$29FF in this case)
0193+  2AF0             GET_CHAR_BITS:
0194+  2AF0 CB 27           SLA A                               ; (?) multiply by two
0195+  2AF2 87              ADD A,A                             ; multiply by four
0196+  2AF3 87              ADD A,A                             ; multiply by eight
0197+  2AF4             
0198+  2AF4 26 14           LD H,$14                            ; load H with half the address of character set.
0199+  2AF6 CB 14           RL H                                ; now $28 or $29 (with carry)
0200+  2AF8 83              ADD A,E                             ; add byte offset 0-7
0201+  2AF9 6F              LD L,A                              ; now HL addresses character source byte
0202+  2AFA             
0203+  2AFA CB 11           RL C                                ; test character, setting carry if inverse.
0204+  2AFC 9F              SBC A,A                             ; accumulator now $00 if normal, $FF if inverse.
0205+  2AFD             
0206+  2AFD AE              XOR (HL)                            ; combine with bit pattern at end or ROM.
0207+  2AFE             
0208+  2AFE C3 51 0A        JP L_0A51                           ; Back to original code (matches ZX81 from here)
0190   2B01             .INCLUDE "LoadSave.asm"
0001+  2B01             ;###############################################################################
0002+  2B01             ; Replacement LOAD and SAVE functions for Lambda 8300 BASIC for the Minstrel 4th
0003+  2B01             ; Dave Curran 2026-06-17
0004+  2B01             ;###############################################################################
0005+  2B01             
0006+  2B01             ;###############################################################################
0007+  2B01             ; replacement SAVE function with countdown
0008+  2B01             NEW_SAVE: 
0009+  2B01             
0010+  2B01 CD 70 03        CALL SUB_0370                       ; routine SET-FAST
0011+  2B04             
0012+  2B04 CD 1D 2C        CALL GET_NAME                       ; get user supplied program name
0013+  2B07 38 74           JR C,F02F4                          ; back with null name to REPORT-F above.
0014+  2B09             
0015+  2B09 F5              PUSH AF                             ; Save registers
0016+  2B0A C5              PUSH BC                             ; 
0017+  2B0B D5              PUSH DE                             ; 
0018+  2B0C E5              PUSH HL                             ; 
0019+  2B0D             
0020+  2B0D CD 35 2C        CALL DRAW_BOX
0021+  2B10             
0022+  2B10 11 69 25        LD DE, LINE2_POS                    ; draw the SAVING message
0023+  2B13 21 BA 2C        LD HL, SAVING_DOTS 
0024+  2B16 01 0E 00        LD BC, BOX_LENGTH
0025+  2B19 ED B0           LDIR
0026+  2B1B             
0027+  2B1B E1              POP HL                              ; Restore registers
0028+  2B1C D1              POP DE                              ; 
0029+  2B1D C1              POP BC                              ; 
0030+  2B1E F1              POP AF                              ; 
0031+  2B1F             
0032+  2B1F             ;; SAVE
0033+  2B1F FD 36 09 FF     LD (IY+$09),$FF                     ; Set version to $FF, indicating Lambda 8300 program
0034+  2B23 EB              EX DE,HL                            ;
0035+  2B24 11 CB 12        LD DE,$12CB                         ; five seconds timing value
0036+  2B27             
0037+  2B27             ;; HEADER
0038+  2B27 CD 3B 11    F02FF: CALL SUB_113B                    ; routine BREAK-1
0039+  2B2A 30 43           JR NC,F0332                         ; to BREAK-2
0040+  2B2C             
0041+  2B2C             ;; DELAY-1
0042+  2B2C 10 FE       F0304: DJNZ F0304                       ; to DELAY-1
0043+  2B2E             
0044+  2B2E 1B              DEC DE                              ;
0045+  2B2F 7A              LD A,D                              ;
0046+  2B30 B3              OR E                                ;
0047+  2B31 20 F4           JR NZ,F02FF                         ; back for delay to HEADER
0048+  2B33             
0049+  2B33             ;; OUT-NAME
0050+  2B33 CD 56 2B    F030B: CALL F031E                       ; routine OUT-BYTE
0051+  2B36 CB 7E           BIT 7,(HL)                          ; test for inverted bit.
0052+  2B38 23              INC HL                              ; address next character of name.
0053+  2B39 28 F8           JR Z,F030B                          ; back if not inverted to OUT-NAME
0054+  2B3B             
0055+  2B3B             ; now start saving the system variables onwards.
0056+  2B3B             
0057+  2B3B 21 09 40        LD HL,$4009                         ; set start of area to VERSN thereby
0058+  2B3E                                                     ; preserving RAMTOP etc.
0059+  2B3E             
0060+  2B3E             ;; OUT-PROG
0061+  2B3E CD 56 2B    F0316: CALL F031E                       ; routine OUT-BYTE
0062+  2B41             
0063+  2B41             ;; Check if finished
0064+  2B41 23              INC HL                              ; next byte
0065+  2B42 E5              PUSH HL                             ; store HL
0066+  2B43 EB              EX DE,HL                            ; move the pointer value to DE
0067+  2B44 2A 14 40        LD HL,($4014)                       ; load HL with E_LINE - the location following
0068+  2B47                                                     ; the variables end-marker.
0069+  2B47 37              SCF                                 ; set carry
0070+  2B48 ED 52           SBC HL,DE                           ; trial subtraction.
0071+  2B4A 38 06           JR C,SAVE_FINISHED                  ; finished, return to main loop
0072+  2B4C             
0073+  2B4C CD 59 2C        CALL DISPLAY_HL                     ; not finished, show the progress
0074+  2B4F             
0075+  2B4F E1              POP HL                              ; restore pointer.
0076+  2B50             
0077+  2B50 18 EC           JR F0316                            ; else back to do another byte.
0078+  2B52             
0079+  2B52             SAVE_FINISHED:
0080+  2B52 E1              POP HL                              ; remove byte address from stack
0081+  2B53 C3 21 02        JP L_0221                           ; LOAD/SAVE-COMPLETE
0082+  2B56             
0083+  2B56             ; -------------------------
0084+  2B56             ; THE 'OUT-BYTE' SUBROUTINE
0085+  2B56             ; -------------------------
0086+  2B56             ; This subroutine outputs a byte a bit at a time to a domestic tape recorder.
0087+  2B56             
0088+  2B56             ;; OUT-BYTE
0089+  2B56 5E          F031E: LD E,(HL)                        ; fetch byte to be saved.
0090+  2B57 37              SCF                                 ; set carry flag - as a marker.
0091+  2B58             
0092+  2B58             ;; EACH-BIT
0093+  2B58 CB 13       F0320: RL E                             ; C < 76543210 < C
0094+  2B5A C8              RET Z                               ; return when the marker bit has passed 
0095+  2B5B                                                     ; right through. >>
0096+  2B5B             
0097+  2B5B 9F              SBC A,A                             ; $FF if set bit or $00 with no carry.
0098+  2B5C E6 05           AND $05                             ; $05 $00
0099+  2B5E C6 04           ADD A,$04                           ; $09 $04
0100+  2B60 4F              LD C,A                              ; transfer timer to C. a set bit has a longer
0101+  2B61                                                     ; pulse than a reset bit.
0102+  2B61             
0103+  2B61             ;; PULSES
0104+  2B61 3E 08       F0329: LD A, $08                        ; set save output high
0105+  2B63 D3 FE           OUT ($FE),A                         ; 
0106+  2B65             
0107+  2B65 06 23           LD B,$23                            ; set timing constant
0108+  2B67             
0109+  2B67             ;; DELAY-2
0110+  2B67 10 FE       F032D: DJNZ F032D                       ; self-loop to DELAY-2
0111+  2B69             
0112+  2B69 AF              XOR A                               ; set save output low
0113+  2B6A D3 FE           OUT ($FE), A                        ;
0114+  2B6C             
0115+  2B6C CD 3B 11        CALL SUB_113B                       ; routine BREAK-1 test for BREAK key. 
0116+  2B6F             
0117+  2B6F             ;; BREAK-2
0118+  2B6F 30 0E       F0332: JR NC,F03A6                      ; forward with break to REPORT-D
0119+  2B71             
0120+  2B71 06 1E           LD B,$1E                            ; set timing value.
0121+  2B73             
0122+  2B73             ;; DELAY-3
0123+  2B73 10 FE       F0336: DJNZ F0336                       ; self-loop to DELAY-3
0124+  2B75             
0125+  2B75 0D              DEC C                               ; decrement counter
0126+  2B76 20 E9           JR NZ,F0329                         ; loop back to PULSES
0127+  2B78             
0128+  2B78             ;; DELAY-4
0129+  2B78 A7          F033B: AND A                            ; clear carry for next bit test.
0130+  2B79 10 FD           DJNZ F033B                          ; self loop to DELAY-4 (B is zero - 256)
0131+  2B7B             
0132+  2B7B 18 DB           JR F0320                            ; loop back to EACH-BIT
0133+  2B7D             
0134+  2B7D             ; --------------
0135+  2B7D             ; THE 'REPORT-F'
0136+  2B7D             ; --------------
0137+  2B7D             
0138+  2B7D             ;; REPORT-F
0139+  2B7D CF          F02F4: RST 08H                          ; ERROR-1
0140+  2B7E 0E              .BYTE $0E                           ; Error Report: No Program Name supplied.
0141+  2B7F             
0142+  2B7F             ;; REPORT-D
0143+  2B7F CF          F03A6: RST 08H                          ; ERROR-1
0144+  2B80 0C              .BYTE $0C                           ; Error Report: BREAK - CONT repeats
0145+  2B81             
0146+  2B81             
0147+  2B81             ;###############################################################################
0148+  2B81             ; replacement LOAD function with countdown
0149+  2B81             
0150+  2B81             NEW_LOAD: 
0151+  2B81             
0152+  2B81 CD 70 03        CALL SUB_0370                       ; routine SET-FAST
0153+  2B84             
0154+  2B84 CD 35 2C        CALL DRAW_BOX
0155+  2B87             
0156+  2B87 11 69 25        LD DE, LINE2_POS                    ; draw the LOADING message
0157+  2B8A 21 AC 2C        LD HL, LOADING_DOTS
0158+  2B8D 01 0E 00        LD BC, BOX_LENGTH
0159+  2B90 ED B0           LDIR
0160+  2B92             
0161+  2B92 CD 1D 2C        CALL GET_NAME                       ; get user supplied program name
0162+  2B95 38 12           JR C,SKIP_NAME                      ; carry set if LOAD ""
0163+  2B97             
0164+  2B97                                                     ; carry clear so LOAD "name"
0165+  2B97                                                     ; DE points to start of name, last character has bit 7 set
