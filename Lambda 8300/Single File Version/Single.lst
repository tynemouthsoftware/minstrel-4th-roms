8140   2A40             ;##############################################################################
8141   2A40             ; Init and display functions for Lambda 8300 BASIC for the Minstrel 4th
8142   2A40             ; Dave Curran 2026-06-18
8143   2A40             ;##############################################################################
8144   2A40             
8145   2A40             ;##############################################################################
8146   2A40             ; Initialisation code for the 4th
8147   2A40             ;
8148   2A40             ; Clear the video RAM and load the Lambda 8300 font into the font RAM
8149   2A40             ; Display a banner, which will remain until first actual CLS
8150   2A40             ;
8151   2A40             
8152   2A40             INIT_4TH:
8153   2A40             
8154   2A40             ; setup UDG $7F as all ones, so the inverted $FF appears like a space
8155   2A40 06 FF           LD B, $FF                           ; set character bitmap in B
8156   2A42 48              LD C, B                             ; and C
8157   2A43 ED 43 F8 2F     LD ($2FF8),BC                       ; write 8 rows, 2 at a time
8158   2A47 ED 43 FA 2F     LD ($2FFA),BC                       ;
8159   2A4B ED 43 FC 2F     LD ($2FFC),BC                       ;
8160   2A4F ED 43 FE 2F     LD ($2FFE),BC                       ;
8161   2A53             
8162   2A53             ; now fill the screen with $ff, which should clear it
8163   2A53             INITIAL_SCREEN_CLEAR:
8164   2A53 21 00 24        LD HL, $2400                        ; start of character video RAM
8165   2A56 11 01 24        LD DE, $2401                        ; the next byte
8166   2A59 01 FF 02        LD BC, $02FF                        ; number of bytes to clear - 1
8167   2A5C 36 FF           LD (HL), $FF                        ; set the first byte
8168   2A5E ED B0           LDIR                                ; clear all the rest
8169   2A60             
8170   2A60 AF              XOR A                               ; A = 0
8171   2A61 12              LD (DE), A                          ; make $2700 (first location after screen) zero.
8172   2A62 13              INC DE                              ; make $2701 zero, to indicate initial boot
8173   2A63 12              LD (DE), A                          ; 
8174   2A64             
8175   2A64             ; copy the 8300 font into the first half of font RAM - should be no conflicts, none of these characters are on screen
8176   2A64             COPYFONT: 
8177   2A64 11 00 2C        LD DE, $2C00                        ; Destination is write only font RAM
8178   2A67 21 00 28        LD HL, FONT                         ; Lambda 8300 font in ROM
8179   2A6A 01 00 02        LD BC, $0200                        ; There are 64 bit-mapped 8x8 characters
8180   2A6D ED B0           LDIR                                ; Copy font from ROM to RAM
8181   2A6F             
8182   2A6F             ; copy a banner message to the top of the screen
8183   2A6F             BANNER:
8184   2A6F 11 00 24        LD DE, $2400                        ; top of 4TH video RAM 
8185   2A72 21 D6 2C        LD HL, BANNER_TEXT                  ; banner message
8186   2A75 01 20 00        LD BC, $20                          ; 32 characters
8187   2A78 ED B0           LDIR
8188   2A7A             
8189   2A7A             ; the screen at this point has the banner and the rest are $FF characters
8190   2A7A             ; when the Lambda 8300 init is complete, the first display cycle will overwrite this
8191   2A7A             ; also with the banner, but all the rest of the characters will be $00 as normal
8192   2A7A             ; apart from the inverse K on the edit line
8193   2A7A             
8194   2A7A             ; resume where the initial reset function
8195   2A7A             ON_TO_RAM_CHECK:
8196   2A7A 01 FF FF        LD BC,$FFFF                         ; top of possible RAM.
8197   2A7D C3 89 04        JP L_0489                           ; on to RAM-CHECK.
8198   2A80             
8199   2A80             
8200   2A80             ;###########################################################
8201   2A80             ; Called during clear after init and also after loading
8202   2A80             ; Check if this is init and display the banner
8203   2A80             SHOW_BANNER:
8204   2A80 CD A5 16        CALL SUB_16A5                       ; CURSOR-IN, set cursor on edit line
8205   2A83 CD D0 0B        CALL SUB_0BD0                       ; CLS function
8206   2A86             
8207   2A86 3A 01 27        LD A, ($2701)                       ; Check if this is the initial boot
8208   2A89 A7              AND A                               ; Test
8209   2A8A C2 9D 2A        JP NZ, BANNER_DONE                  ; skip if not
8210   2A8D             
8211   2A8D 11 7D 40        LD DE, $407D                        ; set DFILE as the destination
8212   2A90 13              INC DE                              ; step over the first NL
8213   2A91              
8214   2A91 21 D6 2C        LD HL, BANNER_TEXT                  ; Banner message
8215   2A94 01 20 00        LD BC, $20                          ; 32 characters
8216   2A97 ED B0           LDIR                                ; copy banner
8217   2A99             
8218   2A99 21 01 27        LD HL, $2701                        ; set $2701 to 1 so banner will not be redrawn
8219   2A9C 34              INC (HL)                            ;
8220   2A9D             
8221   2A9D             BANNER_DONE:
8222   2A9D CD 85 02        CALL SUB_0285                       ; SLOW-FAST to set SLOW mode
8223   2AA0 C3 02 05        JP L_04FF+3                         ; jump back in just after the CLS
8224   2AA3             
8225   2AA3             ;##########################################################
8226   2AA3             ; Copy the Lambda 8300 display file to the 4th screen RAM
8227   2AA3             
8228   2AA3             ; Optimised for fully expanded fixed locate DFILE
8229   2AA3             
8230   2AA3             DISPLAY_ROUTINE:
8231   2AA3 21 7D 40        LD HL,$407D                         ; Set HL to the Display File location
8232   2AA6 11 00 24        LD DE,$2400                         ; Set DE to the Minstrel 4th screen RAM 
8233   2AA9 3E 18           LD A,$18                            ; 24 lines
8234   2AAB             
8235   2AAB             COPY_LINE:
8236   2AAB 23              INC HL                              ; skip the HALT / newline
8237   2AAC 01 20 00        LD BC,$0020                         ; 32 characters per line
8238   2AAF ED B0           LDIR                                ; copy line
8239   2AB1             
8240   2AB1 3D              DEC A                               ; finished?
8241   2AB2 20 F7           JR NZ,COPY_LINE                     ; no, more lines
8242   2AB4             
8243   2AB4              
8244   2AB4             
8245   2AB4             ; waste time to be 100% Lambda 8300 speed
8246   2AB4             ; yes, I did just keep adding and removing delays until it matched.
8247   2AB4             ; LD B, $E3                             ; initial delay count
8248   2AB4             
8249   2AB4             ; WASTE_TIME:
8250   2AB4             ; NOP
8251   2AB4             ; NOP
8252   2AB4             ; NOP
8253   2AB4             ; DJNZ WASTE_TIME 
8254   2AB4             
8255   2AB4             ; end of frame
8256   2AB4              
8257   2AB4 3A 3B 40        LD A,($403B)                        ; get CDFLAG - DO NOT USE IY HERE
8258   2AB7 CB 7F           BIT 7,A                             ; check for slow mode
8259   2AB9             
8260   2AB9 C2 BF 2A        JP NZ, END_SLOW                     ; fast mode?
8261   2ABC             
8262   2ABC             ; End the frame in fast mode. 
8263   2ABC             ; Waste time until for the interrupt then go onto the next frame
8264   2ABC             END_FAST:
8265   2ABC FB              EI                                  ; enable interrupts.
8266   2ABD 76              HALT                                ; halt and wait for the next interrupt
8267   2ABE              
8268   2ABE C9              RET                                 ; onto DISPLAY-1, start of the next frame
8269   2ABF             
8270   2ABF             ; End the frame in slow mode.
8271   2ABF             ; return to users code until interrupted by the IRQ
8272   2ABF             END_SLOW
8273   2ABF E1              POP HL                              ; Throw away the call address 
8274   2AC0             
8275   2AC0 E1              POP HL                              ; ****
8276   2AC1 D1              POP DE                              ; ***
8277   2AC2 C1              POP BC                              ; **
8278   2AC3 F1              POP AF                              ; * Restore Main Registers
8279   2AC4             
8280   2AC4 FB              EI                                  ; enable frame interrupts
8281   2AC5             
8282   2AC5 C9              RET                                 ; return - end of interrupt. Return is to 
8283   2AC6                                                     ; user's program - BASIC or machine code.
8284   2AC6                                                     ; which will be interrupted by every NMI.
8285   2AC6             
8286   2AC6             
8287   2AC6             
8288   2AC6             ;###########################################################
8289   2AC6             ; clear the screen to indicate "fast" mode where the ZX80/1 
8290   2AC6             ; would have stopped producing a television picture
8291   2AC6             
8292   2AC6             NEW_FAST:
8293   2AC6 CD 70 03        CALL SUB_0370                       ; routine SET-FAST
8294   2AC9 FD CB 3B B6     RES 6,(IY+$3B)                      ; Clear request CDFLAG
8295   2ACD             
8296   2ACD E5              PUSH HL
8297   2ACE D5              PUSH DE
8298   2ACF C5              PUSH BC
8299   2AD0             
8300   2AD0 21 00 24        LD HL, $2400                        ; start of video RAM
8301   2AD3 11 01 24        LD DE, $2401                        ; the next byte
8302   2AD6 01 FF 02        LD BC, $02FF                        ; number of bytes to clear -1
8303   2AD9 AF              XOR A                               ; clear A
8304   2ADA 77              LD (HL), A                          ; clear the first byte
8305   2ADB ED B0           LDIR                                ; set all the rest to match
8306   2ADD             
8307   2ADD C1              POP BC
8308   2ADE D1              POP DE
8309   2ADF E1              POP HL
8310   2AE0             
8311   2AE0 C9              RET
8312   2AE1             
8313   2AE1             ;###################################################################
8314   2AE1             ; The load routine detects if the program originated from a ZX81. 
8315   2AE1             ; If it did, it patches it up to run.
8316   2AE1             ; Extra routine to patch the font to reinstate 6 altered characters
8317   2AE1             ; (also overwrites two unchanged characters to save having two loops)
8318   2AE1             PATCH_FONT: 
8319   2AE1 11 40 2C        LD DE, $2C40                        ; Destination is write only font RAM
8320   2AE4 21 00 2A        LD HL, ZX81_FONT                    ; zx81 font characters $08-$0F in ROM
8321   2AE7 01 40 00        LD BC, $0040                        ; There are 8 bit-mapped 8x8 characters
8322   2AEA ED B0           LDIR                                ; Copy font from ROM to RAM
8323   2AEC             
8324   2AEC                                                     ; this is the line of code we replaced
8325   2AEC 2A 0C 40        LD HL,($400C)                       ; Location of the ZX81 DFILE (loaded with program)
8326   2AEF             
8327   2AEF C9              RET                                 ; back to LOAD/SAVE
8328   2AF0             
8329   2AF0             ;###################################################################
8330   2AF0             ; A variation of the ZX81 function in the second half of COPY_NEXT
8331   2AF0             ; Read character data from the font in ROM ($2800-$29FF in this case)
8332   2AF0             GET_CHAR_BITS:
8333   2AF0 CB 27           SLA A                               ; (?) multiply by two
8334   2AF2 87              ADD A,A                             ; multiply by four
8335   2AF3 87              ADD A,A                             ; multiply by eight
8336   2AF4             
8337   2AF4 26 14           LD H,$14                            ; load H with half the address of character set.
8338   2AF6 CB 14           RL H                                ; now $28 or $29 (with carry)
8339   2AF8 83              ADD A,E                             ; add byte offset 0-7
8340   2AF9 6F              LD L,A                              ; now HL addresses character source byte
8341   2AFA             
8342   2AFA CB 11           RL C                                ; test character, setting carry if inverse.
8343   2AFC 9F              SBC A,A                             ; accumulator now $00 if normal, $FF if inverse.
8344   2AFD             
8345   2AFD AE              XOR (HL)                            ; combine with bit pattern at end or ROM.
8346   2AFE             
8347   2AFE C3 51 0A        JP L_0A51                           ; Back to original code (matches ZX81 from here)
8348   2B01             
8349   2B01             ;###############################################################################
8350   2B01             ; Replacement LOAD and SAVE functions for Lambda 8300 BASIC for the Minstrel 4th
8351   2B01             ; Dave Curran 2026-06-17
8352   2B01             ;###############################################################################
8353   2B01             
8354   2B01             ;###############################################################################
8355   2B01             ; replacement SAVE function with countdown
8356   2B01             NEW_SAVE: 
8357   2B01             
8358   2B01 CD 70 03        CALL SUB_0370                       ; routine SET-FAST
8359   2B04             
8360   2B04 CD 1D 2C        CALL GET_NAME                       ; get user supplied program name
8361   2B07 38 74           JR C,F02F4                          ; back with null name to REPORT-F above.
8362   2B09             
8363   2B09 F5              PUSH AF                             ; Save registers
8364   2B0A C5              PUSH BC                             ; 
8365   2B0B D5              PUSH DE                             ; 
8366   2B0C E5              PUSH HL                             ; 
8367   2B0D             
8368   2B0D CD 35 2C        CALL DRAW_BOX
8369   2B10             
8370   2B10 11 69 25        LD DE, LINE2_POS                    ; draw the SAVING message
8371   2B13 21 BA 2C        LD HL, SAVING_DOTS 
8372   2B16 01 0E 00        LD BC, BOX_LENGTH
8373   2B19 ED B0           LDIR
8374   2B1B             
8375   2B1B E1              POP HL                              ; Restore registers
8376   2B1C D1              POP DE                              ; 
8377   2B1D C1              POP BC                              ; 
8378   2B1E F1              POP AF                              ; 
8379   2B1F             
8380   2B1F             ;; SAVE
8381   2B1F FD 36 09 FF     LD (IY+$09),$FF                     ; Set version to $FF, indicating Lambda 8300 program
8382   2B23 EB              EX DE,HL                            ;
8383   2B24 11 CB 12        LD DE,$12CB                         ; five seconds timing value
8384   2B27             
8385   2B27             ;; HEADER
8386   2B27 CD 3B 11    F02FF: CALL SUB_113B                    ; routine BREAK-1
8387   2B2A 30 43           JR NC,F0332                         ; to BREAK-2
8388   2B2C             
8389   2B2C             ;; DELAY-1
8390   2B2C 10 FE       F0304: DJNZ F0304                       ; to DELAY-1
8391   2B2E             
8392   2B2E 1B              DEC DE                              ;
8393   2B2F 7A              LD A,D                              ;
8394   2B30 B3              OR E                                ;
8395   2B31 20 F4           JR NZ,F02FF                         ; back for delay to HEADER
8396   2B33             
8397   2B33             ;; OUT-NAME
8398   2B33 CD 56 2B    F030B: CALL F031E                       ; routine OUT-BYTE
8399   2B36 CB 7E           BIT 7,(HL)                          ; test for inverted bit.
8400   2B38 23              INC HL                              ; address next character of name.
8401   2B39 28 F8           JR Z,F030B                          ; back if not inverted to OUT-NAME
8402   2B3B             
8403   2B3B             ; now start saving the system variables onwards.
8404   2B3B             
8405   2B3B 21 09 40        LD HL,$4009                         ; set start of area to VERSN thereby
8406   2B3E                                                     ; preserving RAMTOP etc.
8407   2B3E             
8408   2B3E             ;; OUT-PROG
8409   2B3E CD 56 2B    F0316: CALL F031E                       ; routine OUT-BYTE
8410   2B41             
8411   2B41             ;; Check if finished
8412   2B41 23              INC HL                              ; next byte
8413   2B42 E5              PUSH HL                             ; store HL
8414   2B43 EB              EX DE,HL                            ; move the pointer value to DE
8415   2B44 2A 14 40        LD HL,($4014)                       ; load HL with E_LINE - the location following
8416   2B47                                                     ; the variables end-marker.
8417   2B47 37              SCF                                 ; set carry
8418   2B48 ED 52           SBC HL,DE                           ; trial subtraction.
8419   2B4A 38 06           JR C,SAVE_FINISHED                  ; finished, return to main loop
8420   2B4C             
8421   2B4C CD 59 2C        CALL DISPLAY_HL                     ; not finished, show the progress
8422   2B4F             
8423   2B4F E1              POP HL                              ; restore pointer.
8424   2B50             
8425   2B50 18 EC           JR F0316                            ; else back to do another byte.
8426   2B52             
8427   2B52             SAVE_FINISHED:
8428   2B52 E1              POP HL                              ; remove byte address from stack
8429   2B53 C3 21 02        JP L_0221                           ; LOAD/SAVE-COMPLETE
8430   2B56             
8431   2B56             ; -------------------------
8432   2B56             ; THE 'OUT-BYTE' SUBROUTINE
8433   2B56             ; -------------------------
8434   2B56             ; This subroutine outputs a byte a bit at a time to a domestic tape recorder.
8435   2B56             
8436   2B56             ;; OUT-BYTE
8437   2B56 5E          F031E: LD E,(HL)                        ; fetch byte to be saved.
8438   2B57 37              SCF                                 ; set carry flag - as a marker.
8439   2B58             
8440   2B58             ;; EACH-BIT
8441   2B58 CB 13       F0320: RL E                             ; C < 76543210 < C
8442   2B5A C8              RET Z                               ; return when the marker bit has passed 
8443   2B5B                                                     ; right through. >>
8444   2B5B             
8445   2B5B 9F              SBC A,A                             ; $FF if set bit or $00 with no carry.
8446   2B5C E6 05           AND $05                             ; $05 $00
8447   2B5E C6 04           ADD A,$04                           ; $09 $04
8448   2B60 4F              LD C,A                              ; transfer timer to C. a set bit has a longer
8449   2B61                                                     ; pulse than a reset bit.
8450   2B61             
8451   2B61             ;; PULSES
8452   2B61 3E 08       F0329: LD A, $08                        ; set save output high
8453   2B63 D3 FE           OUT ($FE),A                         ; 
8454   2B65             
8455   2B65 06 23           LD B,$23                            ; set timing constant
8456   2B67             
8457   2B67             ;; DELAY-2
8458   2B67 10 FE       F032D: DJNZ F032D                       ; self-loop to DELAY-2
8459   2B69             
8460   2B69 AF              XOR A                               ; set save output low
8461   2B6A D3 FE           OUT ($FE), A                        ;
8462   2B6C             
8463   2B6C CD 3B 11        CALL SUB_113B                       ; routine BREAK-1 test for BREAK key. 
8464   2B6F             
8465   2B6F             ;; BREAK-2
8466   2B6F 30 0E       F0332: JR NC,F03A6                      ; forward with break to REPORT-D
8467   2B71             
8468   2B71 06 1E           LD B,$1E                            ; set timing value.
8469   2B73             
8470   2B73             ;; DELAY-3
8471   2B73 10 FE       F0336: DJNZ F0336                       ; self-loop to DELAY-3
8472   2B75             
8473   2B75 0D              DEC C                               ; decrement counter
8474   2B76 20 E9           JR NZ,F0329                         ; loop back to PULSES
8475   2B78             
8476   2B78             ;; DELAY-4
8477   2B78 A7          F033B: AND A                            ; clear carry for next bit test.
8478   2B79 10 FD           DJNZ F033B                          ; self loop to DELAY-4 (B is zero - 256)
8479   2B7B             
8480   2B7B 18 DB           JR F0320                            ; loop back to EACH-BIT
8481   2B7D             
8482   2B7D             ; --------------
8483   2B7D             ; THE 'REPORT-F'
8484   2B7D             ; --------------
8485   2B7D             
8486   2B7D             ;; REPORT-F
8487   2B7D CF          F02F4: RST 08H                          ; ERROR-1
8488   2B7E 0E              .BYTE $0E                           ; Error Report: No Program Name supplied.
8489   2B7F             
8490   2B7F             ;; REPORT-D
8491   2B7F CF          F03A6: RST 08H                          ; ERROR-1
8492   2B80 0C              .BYTE $0C                           ; Error Report: BREAK - CONT repeats
8493   2B81             
8494   2B81             
8495   2B81             ;###############################################################################
8496   2B81             ; replacement LOAD function with countdown
8497   2B81             
8498   2B81             NEW_LOAD: 
8499   2B81             
8500   2B81 CD 70 03        CALL SUB_0370                       ; routine SET-FAST
8501   2B84             
8502   2B84 CD 35 2C        CALL DRAW_BOX
8503   2B87             
8504   2B87 11 69 25        LD DE, LINE2_POS                    ; draw the LOADING message
8505   2B8A 21 AC 2C        LD HL, LOADING_DOTS
8506   2B8D 01 0E 00        LD BC, BOX_LENGTH
8507   2B90 ED B0           LDIR
8508   2B92             
8509   2B92 CD 1D 2C        CALL GET_NAME                       ; get user supplied program name
8510   2B95 38 12           JR C,SKIP_NAME                      ; carry set if LOAD ""
8511   2B97             
8512   2B97                                                     ; carry clear so LOAD "name"
8513   2B97                                                     ; DE points to start of name, last character has bit 7 set
8514   2B97             
8515   2B97 42              LD B, D                             ; save address in BC
8516   2B98 4B              LD C, E                             ;
8517   2B99             
8518   2B99             WAIT_FOR_NAME:
8519   2B99 60              LD H, B                             ; load address from BC
8520   2B9A 69              LD L, C                             ;
8521   2B9B              
8522   2B9B             CHECK_NAME: 
8523   2B9B CD D3 2B        CALL LOAD_BYTE                      ; load a byte
8524   2B9E 38 DF           JR C, F03A6                         ; break pressed before load started, recover
8525   2BA0 BE              CP (HL)                             ; check if it matches name
8526   2BA1 20 F6           JR NZ, WAIT_FOR_NAME                ; no match, wait again - add delay???
8527   2BA3             
8528   2BA3 23              INC HL                              ; address next character of name
8529   2BA4 17              RLA                                 ; test bit 7
8530   2BA5 30 F4           JR NC,CHECK_NAME                    ; no, continue checking
8531   2BA7 18 08           JR LOAD_PROG                        ; name matched, now load the program
8532   2BA9             
8533   2BA9             SKIP_NAME:
8534   2BA9 CD D3 2B        CALL LOAD_BYTE                      ; load a byte
8535   2BAC 38 D1           JR C, F03A6                         ; break pressed before load started, recover
8536   2BAE             
8537   2BAE 17              RLA                                 ; bit 7 -> carry
8538   2BAF 30 F8           JR NC, SKIP_NAME                    ; loop back until name skipped
8539   2BB1             
8540   2BB1             LOAD_PROG:
8541   2BB1                                                     ; name has been skipped / matched, now start loading the program
8542   2BB1              
8543   2BB1 FD 34 15        INC (IY+$15)                        ; increment E_LINE_MSB to avoid load fail before it is overwritten
8544   2BB4 21 09 40        LD HL, $4009                        ; set start load location
8545   2BB7             
8546   2BB7             LOADING:
8547   2BB7 CD D3 2B        CALL LOAD_BYTE                      ; load a byte
8548   2BBA DA 40 2A        JP C, INIT_4TH                      ; break pressed after load started, reset
8549   2BBD             
8550   2BBD 77              LD (HL),A                           ; store byte
8551   2BBE             
8552   2BBE 23              INC HL                              ; next byte
8553   2BBF E5              PUSH HL                             ; store HL
8554   2BC0 EB              EX DE,HL                            ; move the pointer value to DE
8555   2BC1 2A 14 40        LD HL,($4014)                       ; load HL with E_LINE - the location following
8556   2BC4                                                     ; the variables end-marker.
8557   2BC4 37              SCF                                 ; set carry
8558   2BC5 ED 52           SBC HL,DE                           ; trial subtraction.
8559   2BC7              
8560   2BC7 38 06           JR C,LOAD_FINISHED                  ; finished
8561   2BC9             
8562   2BC9 CD 59 2C        CALL DISPLAY_HL                     ; not finished, show the progress
8563   2BCC             
8564   2BCC E1              POP HL                              ; restore load pointer
8565   2BCD 18 E8           JR LOADING                          ; else for more
8566   2BCF             
8567   2BCF             LOAD_FINISHED:
8568   2BCF E1              POP HL                              ; remove byte address from stack
8569   2BD0 C3 21 02        JP L_0221                           ; LOAD/SAVE-COMPLETE
8570   2BD3             
8571   2BD3             
8572   2BD3             ;##########################################################
8573   2BD3             ; Load a byte
8574   2BD3             ; count transitions
8575   2BD3             ; """"VVVV""""" = 0
8576   2BD3             ; """"VVVVVVVVV""""" = 1
8577   2BD3              
8578   2BD3             ; A scratch
8579   2BD3             ; B pulse timer
8580   2BD3             ; C transition counter
8581   2BD3             ; D previous value of the io port (masked)
8582   2BD3             ; E bit counter
8583   2BD3             ; L byte store
8584   2BD3             
8585   2BD3             ; returns byte in A
8586   2BD3             ; carry set if break pressed
8587   2BD3             ;##########################################################
8588   2BD3             
8589   2BD3             IO_FE_MASK .EQU %00100001               ; mask for tape and space column
8590   2BD3             
8591   2BD3             LOAD_BYTE:
8592   2BD3 D9              EXX                                 ; swap to backup register set
8593   2BD4             
8594   2BD4             LOAD_AGAIN:
8595   2BD4 1E 08           LD E, $08                           ; load bit counter
8596   2BD6              
8597   2BD6             LOAD_BIT:
8598   2BD6 0E 00           LD C, $00                           ; clear transition counter
8599   2BD8             
8600   2BD8             LOAD_WAIT:
8601   2BD8                                                     ; wait for the next bit to start
8602   2BD8 3E 7F           LD A,$7F                            ; read from port $7FFE.
8603   2BDA DB FE           IN A,($FE)                          ; the keyboard row with space.
8604   2BDC E6 21           AND IO_FE_MASK                      ; mask all but the tape and space column bits
8605   2BDE             
8606   2BDE BA              CP D                                ; test if this is the same as the previous byte
8607   2BDF CA D8 2B        JP Z, LOAD_WAIT                     ; if the same, keep waiting
8608   2BE2              
8609   2BE2 CB 47           BIT 0, A                            ; has this changed becase of the space key?
8610   2BE4 CA 1A 2C        JP Z, LOAD_BREAK                    ; yes space / break pressed
8611   2BE7             
8612   2BE7 57              LD D, A                             ; store previous value
8613   2BE8             
8614   2BE8             LOAD_PULSE:
8615   2BE8 06 14           LD B, $14                           ; number of tests before bit transitions over
8616   2BEA             
8617   2BEA             LOAD_TEST:
8618   2BEA 3E 7F           LD A,$7F                            ; read from port $7FFE.
8619   2BEC DB FE           IN A,($FE)                          ; the keyboard row with space.
8620   2BEE E6 21           AND IO_FE_MASK                      ; mask all but the tape and space column bits
8621   2BF0             
8622   2BF0 BA              CP D                                ; test if this is the same as the previous byte
8623   2BF1 CA FD 2B        JP Z, LOAD_SAME                     ; if the same, different skip forward
8624   2BF4              
8625   2BF4 CB 47           BIT 0, A                            ; has this changed becase of the space key?
8626   2BF6 CA 1A 2C        JP Z, LOAD_BREAK                    ; yes space / break pressed
8627   2BF9             
8628   2BF9 0C              INC C                               ; transition detected, increment counter
8629   2BFA 57              LD D, A                             ; store previous value
8630   2BFB             
8631   2BFB 18 EB           JR LOAD_PULSE                       ; loop back for more
8632   2BFD             
8633   2BFD             LOAD_SAME:
8634   2BFD 10 EB           DJNZ LOAD_TEST                      ; keep looping up to 16 times
8635   2BFF             
8636   2BFF                                                     ; no transition has been detected for 16 tests, end of this bit
8637   2BFF             
8638   2BFF 79              LD A, C                             ; check the transition count
8639   2C00              
8640   2C00 FE 04           CP $04                              ; is it < 4
8641   2C02 38 D0           JR C, LOAD_AGAIN                    ; error, start again
8642   2C04             
8643   2C04 FE 0A           CP $0A                              ; is C < 10
8644   2C06 38 06           JR C, LOAD_ZERO                     ; it's a zero
8645   2C08             
8646   2C08 FE 14           CP $14                              ; is C < 20
8647   2C0A 38 05           JR C, LOAD_ONE                      ; it's a one
8648   2C0C             
8649   2C0C 18 C6           JR LOAD_AGAIN                       ; error, start again
8650   2C0E             
8651   2C0E             LOAD_ZERO:
8652   2C0E A7              AND A                               ; clear carry flag
8653   2C0F 18 00           JR LOAD_NEXT
8654   2C11             
8655   2C11             LOAD_ONE:
8656   2C11                                                     ; carry already set
8657   2C11             
8658   2C11             LOAD_NEXT:
8659   2C11 CB 15           RL L                                ; rotate the bit into position in the byte store
8660   2C13              
8661   2C13 1D              DEC E                               ; decrememnt bit counter
8662   2C14 20 C0           JR NZ, LOAD_BIT                     ; get next bit
8663   2C16             
8664   2C16                                                     ; 8 bits complete
8665   2C16             
8666   2C16 7D              LD A, L                             ; received byte to A
8667   2C17 D9              EXX                                 ; restore normal registers 
8668   2C18 A7              AND A                               ; clear carry flag
8669   2C19 C9              RET                                 ;
8670   2C1A             
8671   2C1A             LOAD_BREAK:
8672   2C1A D9              EXX                                 ; restore normal registers 
8673   2C1B 37              SCF                                 ; set the carry flag to indicate break pressed
8674   2C1C C9              RET                                 ; 
8675   2C1D             
8676   2C1D             
8677   2C1D             ;###############################################################################
8678   2C1D             ; GET_NAME
8679   2C1D             ; parse the user input to get the program name
8680   2C1D             
8681   2C1D             GET_NAME:
8682   2C1D CD 4A 11        CALL SUB_114A                       ; routine SCANNING
8683   2C20 3A 01 40        LD A,($4001)                        ; sv FLAGS
8684   2C23 87              ADD A,A                             ;
8685   2C24 FA 33 04        JP M,L_0433                         ; to REPORT-C
8686   2C27             
8687   2C27 E1              POP HL                              ;
8688   2C28 D0              RET NC                              ;
8689   2C29             
8690   2C29 E5              PUSH HL                             ;
8691   2C2A CD ED 15        CALL SUB_15ED                       ; routine STK-FETCH
8692   2C2D 62              LD H,D                              ;
8693   2C2E 6B              LD L,E                              ;
8694   2C2F 0D              DEC C                               ;
8695   2C30 F8              RET M                               ;
8696   2C31             
8697   2C31 09              ADD HL,BC                           ;
8698   2C32 CB FE           SET 7,(HL)                          ;
8699   2C34 C9              RET                                 ;
8700   2C35             
8701   2C35             ;###############################################################################
8702   2C35             ; display loading screen
8703   2C35             ; /------------\
8704   2C35             ; |LOADING ....|
8705   2C35             ; \------------/
8706   2C35             
8707   2C35             DRAW_BOX:
8708   2C35              
8709   2C35 AF              XOR A                               ; clear the screen, using A=0
8710   2C36 21 00 24        LD HL, $2400                        ; start of video RAM
8711   2C39 11 01 24        LD DE, $2401                        ; the next byte
8712   2C3C 01 00 03        LD BC, $0300                        ; number of bytes to clear (including $2700)
8713   2C3F 77              LD (HL), A                          ; Clear the first byte
8714   2C40 ED B0           LDIR                                ; Clear all the rest
8715   2C42              
8716   2C42 11 49 25        LD DE, LINE1_POS                    ; draw the top of the box
8717   2C45 21 9E 2C        LD HL, BOX_TOP 
8718   2C48 01 0E 00        LD BC, BOX_LENGTH
8719   2C4B ED B0           LDIR
8720   2C4D             
8721   2C4D 11 89 25        LD DE, LINE3_POS                    ; draw the bottom of the box
8722   2C50 21 C8 2C        LD HL, BOX_BOTTOM
8723   2C53 01 0E 00        LD BC, BOX_LENGTH
8724   2C56 ED B0           LDIR
8725   2C58             
8726   2C58 C9              RET
8727   2C59             
8728   2C59             ;###############################################################################
8729   2C59             ; diplay the current value of HL in the loading / saving box
8730   2C59             ; works from right to left, updating as few digits as necessary
8731   2C59             ; (if a digit is not 0, then don't update anything to it's left)
8732   2C59             
8733   2C59             DISPLAY_HL: 
8734   2C59 11 75 25        LD DE, DIGITS_POS+3
8735   2C5C             DISPLAY_HL2:
8736   2C5C 0E 0F           LD C, $0F                           ; 0F is used a lot, so preload it 
8737   2C5E              
8738   2C5E                                                     ; start with the LSB ...L
8739   2C5E 7D              LD A, L
8740   2C5F A1              AND C
8741   2C60 C6 1C           ADD A, _0
8742   2C62 12              LD (DE), A
8743   2C63 1B              DEC DE
8744   2C64             
