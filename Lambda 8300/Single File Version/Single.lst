2496   0ABD 91              SUB C
2497   0ABE 4F              LD C,A
2498   0ABF 3E 18           LD A,$18
2499   0AC1 90              SUB B
2500   0AC2 6F              LD L,A
2501   0AC3 26 00           LD H,$00
2502   0AC5 06 05           LD B,$05
2503   0AC7             L_0AC7:
2504   0AC7 29              ADD HL,HL
2505   0AC8 10 FD           DJNZ L_0AC7
2506   0ACA 09              ADD HL,BC
2507   0ACB 4F              LD C,A
2508   0ACC 09              ADD HL,BC
2509   0ACD 01 7E 40        LD BC,$407E                         ; position of top left character (fixed DFILE location)
2510   0AD0 09              ADD HL,BC                           ; add offset to get address of character
2511   0AD1 22 0E 40        LD ($400E),HL                       ; Set DF.CC - Display file current character
2512   0AD4 06 00           LD B,$00
2513   0AD6 C9              RET
2514   0AD7             
2515   0AD7             ; ------------------------------
2516   0AD7             ; THE 'EXPAND TOKENS' SUBROUTINE
2517   0AD7             ; ------------------------------
2518   0AD7             
2519   0AD7             ; TOKENS
2520   0AD7             SUB_0AD7:
2521   0AD7 F5              PUSH AF
2522   0AD8 CD 07 0B        CALL SUB_0B07
2523   0ADB 30 08           JR NC,L_0AE5
2524   0ADD FD CB 01 46     BIT 0,(IY+$01)
2525   0AE1 20 02           JR NZ,L_0AE5
2526   0AE3 AF              XOR A
2527   0AE4 D7              RST 10H
2528   0AE5             
2529   0AE5             ; ALL-CHARS - different to ZX81
2530   0AE5             L_0AE5:
2531   0AE5 0A              LD A,(BC)
2532   0AE6 E6 3F           AND $3F
2533   0AE8 D7              RST 10H
2534   0AE9 0A              LD A,(BC)
2535   0AEA 03              INC BC
2536   0AEB 87              ADD A,A
2537   0AEC 30 F7           JR NC,L_0AE5
2538   0AEE 4F              LD C,A
2539   0AEF F1              POP AF
2540   0AF0 FE C0           CP $C0
2541   0AF2 30 03           JR NC,L_0AF7
2542   0AF4 FE 43           CP $43
2543   0AF6 D0              RET NC
2544   0AF7             L_0AF7:
2545   0AF7 79              LD A,C
2546   0AF8 FE 1A           CP $1A
2547   0AFA 28 03           JR Z,L_0AFF
2548   0AFC FE 38           CP $38
2549   0AFE D8              RET C
2550   0AFF             
2551   0AFF             ; TRAIL-SP
2552   0AFF             L_0AFF:
2553   0AFF AF              XOR A
2554   0B00 FD CB 01 C6     SET 0,(IY+$01)
2555   0B04 C3 96 09        JP L_0996
2556   0B07             
2557   0B07             ; TOKEN-ADD
2558   0B07             SUB_0B07:
2559   0B07 E5              PUSH HL
2560   0B08 21 F0 00        LD HL,L_00F0                        ; Tokens table
2561   0B0B CB 7F           BIT 7,A
2562   0B0D 28 02           JR Z,L_0B11
2563   0B0F E6 3F           AND $3F
2564   0B11             
2565   0B11             ; TEST-HIGH
2566   0B11             L_0B11:
2567   0B11 FE 46           CP $46                              ; $46 tokens in table
2568   0B13 30 10           JR NC,L_0B25
2569   0B15 47              LD B,A
2570   0B16 04              INC B
2571   0B17             
2572   0B17             ; WORDS
