0738   0300             ; THE 'VIDEO-1' ROUTINE
0739   0300             ; ---------------------
0740   0300             
0741   0300             ; R-IX-1 (timing altered)
0742   0300 01 01 19        LD BC,$1901                         ; B=25 lines, C=1 scanline
0743   0303 3A 00 00        LD A,($0000)                        ; wasting cycles
0744   0306 3E F5           LD A,$F5                            ; Preset value to go into R to cause trigger at correct time
0745   0308 CD 37 03        CALL SUB_0337                       ; DISPLAY-5, border complete, generate text display
0746   030B 00              NOP
0747   030C 00              NOP
0748   030D 2B              DEC HL                              ; back to the previous HALT character
0749   030E CD 14 03        CALL SUB_0314                       ; DISPLAY-3, bottom border
0750   0311 C3 9D 02        JP L_029D                           ; Back to DISPLAY-1
