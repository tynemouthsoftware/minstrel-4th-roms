0001   0000             ; Lamdba 8300 for Minstrel 4th
0002   0000             ; Dave Curran 2026-06-18
0003   0000             
0004   0000             ; Single file (+ font.asm) version
0005   0000             ; TASM.EXE -t80 -f00 -b Single.asm Single.bin
0006   0000             ; Padded with NOPs to fill gaps in existing code
0007   0000             
0008   0000             ; Minstrel 4th Memory Map
0009   0000             ; =======================
0010   0000             
0011   0000             ; RAM
0012   0000             ; ---
0013   0000             ; 2000 - 23FF 1K Video RAM mirror (not used)
0014   0000             ; 2400 - 27FF 1K Video RAM 40x25 characters (read / write)
0015   0000             ; 2800 - 2BFF 1K Font RAM mirror (not used)
0016   0000             ; 2C00 - 2FFF 1K Font RAM 128 characters (write only)
0017   0000             
0018   0000             ; 3C00 - 3FFF 1K System RAM (not used)
0019   0000             
0020   0000             ; 4000 - FFFF 48K RAM (read / write)
0021   0000             
0022   0000             ; ROM
0023   0000             ; ---
0024   0000             ; 0000 - 1FFF 8K ROM
0025   0000             ; 2000 - 27FF 2K (not accessible)
0026   0000             ; 2800 - 3BFF 5K ROM
0027   0000             ; 3C00 - 3FFF 1K (not accessible)
0028   0000             
0029   0000             ; System Variables
0030   0000             
0031   0000             ; $4000     ERR.NR  - Current report code -1
0032   0000             ; $4001     FLAGS   - Some flags
0033   0000             ; $4002/03  ERR.SP  - Address of top of GOSUB stack
0034   0000             ; $4004/05  RAMTOP  - Address of reserved area
0035   0000             ; $4006     MODE    - Cursor mode
0036   0000             ; $4007/08  PPC     - Line number being executed
0037   0000             ; $4009     VERSN   - Version (from tape $00 = ZX81, $FF = Lambda)
0038   0000             ; $400A/0B  NXTLIN  - Address of next line to be executed (ZX81 has E.PPC here)
0039   0000             ; $400C/0D  PRGRM   - Start of user program = $4396 (ZX81 has DFILE here)
0040   0000             ; $400E/0F  DF.CC   - Display file current character
0041   0000             ; $4010/11  VARS    - Start of variable area
0042   0000             ; $4012/13  DEST    - Address of variable being assigned
0043   0000             ; $4014/15  E.LINE  - Address of edit line
0044   0000             ; $4016/17  CH.ADD  - Next character to interpret
0045   0000             ; $4018/19  X.PTR   - Addess of character before syntax error
0046   0000             ; $401A/1B  STKBOT  - Address of calculator stack
0047   0000             ; $401C/1D  STKEND  - End of calculator stack
0048   0000             ; $401E     BREG    - Floating point B register
0049   0000             ; $401F/20  MEM     - Address of calc memory area = MEMBOT
0050   0000             ; $4021     TEMPO   - Setting of music tempo (was SPARE1)
0051   0000             ; $4022     DF.SZ   - Size of editor part of screen
0052   0000             ; $4023/24  S.TOP   - Line number at top of screen
0053   0000             ; $4025/26  LAST.K  - Last keyboard scan
0054   0000             ; $4027     DB.ST   - Keyboard debounce status
0055   0000             ; $4028     MARGIN  - Number of lines in margin
0056   0000             ; $4029/2A  E.PPC   - Line number of line with cursor (ZX81 has NXTLIN here)
0057   0000             ; $402B/2C  OLDPPC  - Address of line where CONT jumps
0058   0000             ; $402D     FLAGX   - Some more flags
0059   0000             ; $402E/F   STRLEN  - String length
0060   0000             ; $4030/31  T.ADDR  - Next item in syntax table
0061   0000             ; $4032/33  SEED    - Seed for RND
0062   0000             ; $4034/35  FRAMES  - Frame counter
0063   0000             ; $4035/37  COORDS  - Last point plotted (to add for DRAW?)
0064   0000             ; $4038     PR.CC   - Address of LPRINT position
0065   0000             ; $4039/3A  S.POSN  - Current PRINT position
0066   0000             ; $403B     CDFLAG  - Compute Display Flags for FAST/SLOW mode (Bit 7 = 1 for SLOW, Bit 6 = 1 to request SLOW mode)
0067   0000             ; $403C-5C  PRBUFF  - Printer buffer
0068   0000             ; $405D-7A  MEMBOT  - Calculator memory
0069   0000             ; $407B-7C  BLINK   - Cursor blink
0070   0000             ; $407D-$4395       - Display file
0071   0000             ; $4396-RAMTOP      - User Program memory
0072   0000             
0073   0000             ; no DFILE system variable - Location of display file, that is hard coded at $407D
0074   0000             DFILE .EQU $407D
0075   0000             
0076   0000             
0077   0000             .ORG $0000
0078   0000             ; -----------
0079   0000             ; THE 'START'
0080   0000             ; -----------
0081   0000             
0082   0000             START:
0083   0000 C3 40 2A        JP INIT_4TH                         ; Initialise the Minstrel 4th video RAM
0084   0003             
0085   0003             ; @@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
0086   0003             ; unused code retained to build binary compatible 
0087   0003 00              nop
0088   0004 00              nop
0089   0005 00              nop
0090   0006 18 1D           jr $0025
0091   0008             ; @@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
0092   0008             
0093   0008             .ORG $0008
0094   0008             ; ---------------------------
0095   0008             ; THE 'ERROR' RESTART RST 08H
0096   0008             ; ---------------------------
0097   0008             ; ERROR-1
0098   0008 2A 16 40        LD HL,($4016)                       ; CH.ADD - Address of next character to interpret
0099   000B 22 18 40        LD ($4018),HL                       ; X.PTR - Address of character before error
0100   000E 18 47           JR ERROR_2                           ;
0101   0010             
0102   0010             
0103   0010             .ORG $0010
0104   0010             ; ---------------------------------------
0105   0010             ; THE 'PRINT A CHARACTER' RESTART RST 10H
0106   0010             ; ---------------------------------------
0107   0010             ; PRINT-A
0108   0010 A7              AND A
0109   0011 C2 92 09        JP NZ,L_0992
0110   0014 C3 96 09        JP L_0996
0111   0017             
0112   0017             ; @@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
0113   0017             ; unused code retained to build binary compatible 
0114   0017 FF              .BYTE $FF                           ; unused
0115   0018             ; @@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
0116   0018             
0117   0018             .ORG $0018
0118   0018             ; -----------------------------------------
0119   0018             ; THE 'COLLECT A CHARACTER' RESTART RST 18H
0120   0018             ; -----------------------------------------
0121   0018             GET_CHAR:
0122   0018 2A 16 40        LD HL,($4016)
0123   001B 7E              LD A,(HL)
0124   001C             GET_CHAR_1:
0125   001C A7              AND A
0126   001D C0              RET NZ
0127   001E                 
0128   001E             ; @@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
0129   001E             ; unused code retained to build binary compatible 
0130   001E 00              NOP
0131   001F 00              NOP
0132   0020             ; @@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
0133   0020             
0134   0020             .ORG $0020
0135   0020             ; --------------------------------------------
0136   0020             ; THE 'COLLECT NEXT CHARACTER' RESTART RST 20H
0137   0020             ; --------------------------------------------
0138   0020             ; NEXT-CHAR
0139   0020 CD 4A 00        CALL INC_CH_ADD
0140   0023 18 F7           JR GET_CHAR_1
0141   0025             
0142   0025             ; @@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
0143   0025             ; unused code retained to build binary compatible 
0144   0025 C3 6E 04        JP $046E
0145   0028             ; @@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
0146   0028             
0147   0028             .ORG $0028
0148   0028             ; -----------------------------------------------
0149   0028             ; THE 'FLOATING POINT CALCULATOR' RESTART RST 28H
0150   0028             ; -----------------------------------------------
0151   0028             ; FP-CALC
0152   0028 C3 94 1B        JP L_1B94
0153   002B             
0154   002B             SUB_END_CALC:
0155   002B F1              POP AF
0156   002C D9              EXX
0157   002D E3              EX (SP),HL
0158   002E D9              EXX
0159   002F C9              RET
0160   0030             
0161   0030             .ORG $0030
0162   0030             ; ------------------------------------
0163   0030             ; THE 'MAKE BC SPACES' RESTART RST 30H
0164   0030             ; ------------------------------------
0165   0030             ; BC-SPACES
0166   0030 C5              PUSH BC
0167   0031 2A 14 40        LD HL,($4014)
0168   0034 E5              PUSH HL
0169   0035 C3 7D 16        JP L_167D
0170   0038             
0171   0038             .ORG $0038
0172   0038             ; --------------------------------
0173   0038             ; THE 'MASKABLE INTERRUPT' ROUTINE
0174   0038             ; --------------------------------
0175   0038             ; Called once every frame
0176   0038             
0177   0038             INTERRUPT:
0178   0038             ; Called once every frame either halted in fast mode or user code in slow
0179   0038 F5              PUSH AF                             ; store the accumulator andflags.
0180   0039              
0181   0039 3A 3B 40        LD A,($403B)                        ; get CDFLAG
0182   003C CB 7F           BIT 7,A                             ; check for slowmode
0183   003E             
0184   003E 20 02           JR NZ,RET_SLOW                      ; skip if SLOW mode
0185   0040              
0186   0040 F1              POP AF                              ; restore the accumulator and flags.
0187   0041 C9              RET                                 ; return for the next frame if FAST mode
0188   0042             
0189   0042             ; Slow mode interrupt - we have interrupted users code
0190   0042             RET_SLOW:
0191   0042              
0192   0042                                                     ; stackcontains:
0193   0042                                                     ; * User code returnaddress
0194   0042                                                     ; ** Previously pushed AF
0195   0042 C5              PUSH BC                             ; *** Remaining Main Registers
0196   0043 D5              PUSH DE                             ; ****
0197   0044 E5              PUSH HL                             ; *****
0198   0045              
0199   0045 C3 9D 02        JP L_029D                           ; ready for the start of the next frame
0200   0048             
0201   0048             ; ---------------------------------
0202   0048             ; THE 'INCREMENT CH-ADD' SUBROUTINE
0203   0048             ; ---------------------------------
0204   0048             
0205   004A             .ORG $004A
0206   004A             INC_CH_ADD:
0207   004A 2A 16 40        LD HL,($4016)
0208   004D             
0209   004D             TEMP_PTR1:
0210   004D 23              INC HL
0211   004E             
0212   004E             TEMP_PTR2:
0213   004E 22 16 40        LD ($4016),HL
0214   0051 7E              LD A,(HL)
0215   0052 FE 7F           CP $7F
0216   0054 C0              RET NZ
0217   0055 18 F6           JR TEMP_PTR1
0218   0057             
0219   0057             ; --------------------
0220   0057             ; THE 'ERROR-2' BRANCH
0221   0057             ; --------------------
0222   0057             
0223   0057             ERROR_2:
0224   0057 E1              POP HL                              ; get error code
0225   0058 6E              LD L,(HL)                           ; extract error byte
0226   0059             
0227   0059             ERROR_3:
0228   0059 FD 75 00        LD (IY+$00),L                       ; set ERR_NR, system error number
0229   005C ED 7B 02 40     LD SP,($4002)                       ; reset stack pointer to top of GOSUB stack
0230   0060 CD 85 02        CALL SUB_0285                       ; SLOW mode
0231   0063 C3 B4 16        JP L_16B4                           ; exit via SET_MIN to clear calculator stack
0232   0066             
0233   0066             ; ------------------------------------
0234   0066             ; THE 'NON MASKABLE INTERRUPT' ROUTINE
0235   0066             ; ------------------------------------
0236   0066             
0237   0066             ; NMI
0238   0066             .ORG $0066
0239   0066 ED 45           RETN                                ; no NMI on 4th
