2595   0B2D             ; --------------------------
2596   0B2D             ; THE 'ONE SPACE' SUBROUTINE
2597   0B2D             ; --------------------------
2598   0B2D             
2599   0B2D             ; ONE-SPACE
2600   0B2D             SUB_0B2D:
2601   0B2D 01 01 00        LD BC,$0001
2602   0B30             
2603   0B30             ; --------------------------
2604   0B30             ; THE 'MAKE ROOM' SUBROUTINE
2605   0B30             ; --------------------------
2606   0B30             
2607   0B30             ; Make room for DE bytes at HL
2608   0B30             
2609   0B30             ; MAKE-ROOM
2610   0B30             SUB_0B30:
2611   0B30 E5              PUSH HL                             ; Save HL
2612   0B31 CD A0 10        CALL SUB_10A0                       ; Routine TEST-ROOM
2613   0B34 E1              POP HL                              ; Restore HL
2614   0B35 CD 3F 0B        CALL SUB_0B3F                       ; Routine POINTERS
2615   0B38 2A 1C 40        LD HL,($401C)                       ; STKEND - End of calculator stack
2616   0B3B EB              EX DE,HL                            ; DE=STKEND, HL=Location of bytes to be moved, BC=number of bytes to move
2617   0B3C ED B8           LDDR                                ; Move bytes
2618   0B3E C9              RET
2619   0B3F             
2620   0B3F             ; -------------------------
2621   0B3F             ; THE 'POINTERS' SUBROUTINE
2622   0B3F             ; -------------------------
2623   0B3F             
2624   0B3F             ; POINTERS
2625   0B3F             SUB_0B3F:
2626   0B3F F5              PUSH AF                             ; Save the Carry from the result of TEST-ROM
2627   0B40 E5              PUSH HL                             ; Save HL, the destination
2628   0B41 21 0A 40        LD HL,$400A                         ; NXTLIN - Address of next line to be executed (ZX81 was $4029)
2629   0B44 3E 0A           LD A,$0A                            ; Number of pointers to test
2630   0B46             
2631   0B46             ; NEXT-PTR
2632   0B46             L_0B46:
2633   0B46 5E              LD E,(HL)
2634   0B47 23              INC HL
2635   0B48 56              LD D,(HL)
2636   0B49 E3              EX (SP),HL                          ; Get destination from stack
2637   0B4A A7              AND A                               ; Clear carry flag
2638   0B4B ED 52           SBC HL,DE                           ; Subtract and restore to set flags
2639   0B4D 19              ADD HL,DE                           ;
2640   0B4E E3              EX (SP),HL                          ; Restore destination to stack
2641   0B4F 30 09           JR NC,L_0B5A                        ; skip to PTR-DONE if pointer below destination
2642   0B51             ; pointer is after point of insertion, so update pointer
2643   0B51 D5              PUSH DE                             ; Save DE
2644   0B52 EB              EX DE,HL
2645   0B53 09              ADD HL,BC                           ; move pointer up by BC bytes
2646   0B54 EB              EX DE,HL
2647   0B55 72              LD (HL),D                           ; Update the pointer
2648   0B56 2B              DEC HL
2649   0B57 73              LD (HL),E
2650   0B58 23              INC HL
2651   0B59 D1              POP DE                              ; Restore DE
2652   0B5A             
2653   0B5A             ; PTR-DONE
2654   0B5A             L_0B5A:
2655   0B5A 23              INC HL                              ; Next pointer
2656   0B5B 3D              DEC A                               ; Reduce number of pointers left to test
2657   0B5C 20 E8           JR NZ,L_0B46                        ; Back to NEXT-PTR if there are more to do
2658   0B5E             
2659   0B5E             ; all pointers updated
2660   0B5E EB              EX DE,HL                            ; HL now contains the end of the space to add + overheads
2661   0B5F D1              POP DE                              ; DE contains the location of the new space
2662   0B60 F1              POP AF
2663   0B61 A7              AND A
2664   0B62 ED 52           SBC HL,DE                           ; HL now contains the number of bytes required
2665   0B64 44              LD B,H                              ; BC=HL
2666   0B65 4D              LD C,L
2667   0B66 03              INC BC                              ; +1
2668   0B67 19              ADD HL,DE                           ; Add back
2669   0B68 EB              EX DE,HL                            ; Finally DE=End of space, HL=Start of space, BC=Size of space
2670   0B69 C9              RET
2671   0B6A             
2672   0B6A             ; -----------------------------
2673   0B6A             ; THE 'LINE ADDRESS' SUBROUTINE
