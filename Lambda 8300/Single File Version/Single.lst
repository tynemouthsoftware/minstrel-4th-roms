0533   0216             
0534   0216             ; ------------------------------
0535   0216             ; THE 'LOAD-SAVE UPDATE' ROUTINE
0536   0216             ; ------------------------------
0537   0216             
0538   0216             ; LOAD/SAVE
0539   0216             SUB_0216:
0540   0216 23              INC HL                              ; Step destination
0541   0217 EB              EX DE,HL                            ; Backup to DE
0542   0218 2A 14 40        LD HL,($4014)                       ; Get E-LINE
0543   021B 37              SCF                                 ; Check if they match
0544   021C ED 52           SBC HL,DE                           ; Is the last byte the end of the file?
0545   021E EB              EX DE,HL                            ; Restore destination
0546   021F D0              RET NC                              ; return if the end has not been reached
0547   0220 E1              POP HL                              ; drop the return address and continue
0548   0221             ; ZX81 drops to SLOW here
0549   0221             
0550   0221             ; LOAD/SAVE-COMPLETE
0551   0221             L_0221:
0552   0221 FD 34 09        INC (IY+$09)                        ; increment version (from tape Lambda = $FF, ZX81 = $00. normal Lambda = $00, ZX81 = $01)
0553   0224 28 5F           JR Z,SUB_0285                       ; if it was $FF, a Lambda program, go straight to FAST/SLOW
0554   0226             
0555   0226             ; This code converts a ZX81 program to the Lambda 8300
0556   0226                 
0557   0226                                                     ; The following line is patched out to insert the function call, which ends with that line and a RET
0558   0226                                                     ;LD HL,($400C)                                                           ; Location of the ZX81 DFILE (loaded with program)
0559   0226 CD E1 2A        CALL PATCH_FONT                     ; If patching a ZX81 program, patch the font as well
0560   0229             
0561   0229 23              INC HL                              ; +1
0562   022A 22 10 40        LD ($4010),HL                       ; Store this as
0563   022D 21 7D 40        LD HL,DFILE                         ; Hard coded DFILE location
0564   0230 01 19 03        LD BC,$0319                         ; Length of DFILE + 1 extra blank row to make SCROLL a block copy
0565   0233 CD 30 0B        CALL SUB_0B30                       ; MAKE-ROOM for BC bytes at location in HL
0566   0236 EB              EX DE,HL                            ; HL is now at the program location
0567   0237             ; ZX81-CONV-1
0568   0237             L_0237:
0569   0237 23              INC HL                              ; Step through memory
0570   0238 3E C0           LD A,$C0
0571   023A A6              AND (HL)                            ; Mask off the top two bits
0572   023B 23              INC HL
0573   023C 23              INC HL
0574   023D 23              INC HL
0575   023E 28 08           JR Z,L_0248                         ; If it was <$30, skip to ZX81-CONV-4
0576   0240 21 96 43        LD HL,$4396                         ; Hard coded number we worked out before (start of program)
0577   0243 C3 AC 04        JP L_04AC                           ; Re-initialise after loading and clear screen etc.
0578   0246             
0579   0246             ; ZX81-CONV-2
0580   0246             L_0246:
0581   0246 80              ADD A,B                             ; modify the command token from ZX81 to Lambda tokens
0582   0247             
0583   0247             ; ZX81-CONV-3
0584   0247             L_0247:
0585   0247 77              LD (HL),A                           ; update the token in the copde
0586   0248             
0587   0248             ; ZX81-CONV-4
0588   0248             L_0248:
0589   0248 23              INC HL                              ; step through program
0590   0249 7E              LD A,(HL)
0591   024A CD 55 09        CALL SUB_0955                       ; routine NUMBER
0592   024D 28 F9           JR Z,L_0248                         ; skip through numbers
0593   024F             
0594   024F FE 76           CP $76                              ; is it a newline?
0595   0251 28 E4           JR Z,L_0237                         ; skip back for next line number
0596   0253 FE E1           CP $E1                              ; is it a command over $E1?
0597   0255 30 F1           JR NC,L_0248                        ; continue scanning
0598   0257 FE 40           CP $40                              ; is it a number character below $40?
0599   0259 38 ED           JR C,L_0248                         ; continue scanning
0600   025B 06 03           LD B,$03
0601   025D FE 43           CP $43                              ; is it a command below $43?
0602   025F 38 E5           JR C,L_0246                         ; add 3
0603   0261 06 62           LD B,$62
0604   0263 FE DE           CP $DE                              ; is it a command above $DE?
0605   0265 30 DF           JR NC,L_0246                        ; add $62
0606   0267 06 FE           LD B,$FE
0607   0269 FE D8           CP $D8                              ; is it cpmmand $D8?
0608   026B 30 D9           JR NC,L_0246                        ; add $FE
0609   026D 06 FC           LD B,$FC
0610   026F FE C4           CP $C4                              ; is it above $C4?
0611   0271 30 D3           JR NC,L_0246                        ; add $FC
0612   0273 06 13           LD B,$13
0613   0275 FE C1           CP $C1                              ; is it above $C1?
0614   0277 30 CD           JR NC,L_0246                        ; add $13
0615   0279 FE C0           CP $C0
0616   027B 20 CB           JR NZ,L_0248                        ; is it not $C0?
0617   027D 3E 17           LD A,$17                            ; replace with dummy command
0618   027F 18 C6           JR L_0247                           ; loop back to write the new value
0619   0281             
0620   0281             ; --------------------------
0621   0281             ; THE 'SLOW' COMMAND ROUTINE
0622   0281             ; --------------------------
0623   0281             
0624   0281             ; SLOW
0625   0281             SUB_0281:
0626   0281 FD CB 3B F6     SET 6,(IY+$3B)                      ; Request slow mode ()
0627   0285             
0628   0285             ; SLOW/FAST
0629   0285             SUB_0285:
0630   0285 21 3B 40        LD HL,$403B                         ; load the CDFLAG
0631   0288 7E              LD A,(HL)
0632   0289 17              RLA                                 ; bit 6 (request) -> bit 7 (current state)
0633   028A AE              XOR (HL)                            ; XOR with actual current state
0634   028B 17              RLA                                 ; result -> carry
0635   028C D0              RET NC                              ; return if already in requested mode
0636   028D             
0637   028D CB FE           SET 7,(HL)                          ; set slow mode - compute and display
0638   028F F5              PUSH AF
0639   0290 C5              PUSH BC
0640   0291 D5              PUSH DE
0641   0292 E5              PUSH HL
0642   0293             
0643   0293             ; Called where DISPLAY-1 usually was
0644   0293             ; PRE-DISPLAY-1
0645   0293             SUB_0293:
0646   0293 18 08           JR L_029D                           ; Bypass PRE-DISPLAY-1
0647   0295                 
0648   0295             ; -----------------------
0649   0295             ; THE 'MAIN DISPLAY' LOOP
0650   0295             ; -----------------------
0651   0295             ; This routine is executed once for every frame displayed.
0652   0295             
0653   0295             ;; DISPLAY-1
0654   029D             .ORG $029D
0655   029D             L_029D:
0656   029D 2A 34 40        LD HL,($4034)                       ; Get the frame count from FRAMES
0657   02A0 2B              DEC HL
0658   02A1 3E 7F           LD A,$7F                            ; Mask bit 7
0659   02A3 A4              AND H                               ; of H
0660   02A4 B5              OR L                                ; and OR with L
0661   02A5 7C              LD A,H                              ;
0662   02A6 20 03           JR NZ,L_02AB                        ; Jump if frame counter bits 0-14 are zero
0663   02A8 17              RLA                                 ; bit 15 of frame counter (1 if paused) to carry
0664   02A9 18 02           JR L_02AD                           ; skip
0665   02AB             
0666   02AB             ; ANOTHER
0667   02AB             L_02AB:
0668   02AB 46              LD B,(HL)                           ; Dummy timing
0669   02AC 37              SCF                                 ; set carry
0670   02AD             
0671   02AD             ; OVER-NC
0672   02AD             L_02AD:
0673   02AD 67              LD H,A
0674   02AE 22 34 40        LD ($4034),HL                       ; Save the new frame count to FRAMES
0675   02B1 D0              RET NC                              ; Return if FRAMES is in use by PAUSE command
0676   02B2             
0677   02B2             ; ZX81 goes string to ; DISPLAY-2
0678   02B2             
0679   02B2             ; Bit 7 of the cursor character is inverted every 16 frames
0680   02B2             ; That makes it flashe approximately 2 times a second
0681   02B2             ; BLINK-CURSOR
0682   02B2 7D              LD A,L                              ; A = LSB of FRAMES
0683   02B3 2A 7B 40        LD HL,($407B)                       ; Address of blinking cursor
0684   02B6 CB 26           SLA (HL)                            ; rotate cursor character
0685   02B8 17              RLA                                 ;
0686   02B9 17              RLA                                 ;
0687   02BA 17              RLA                                 ;
0688   02BB 17              RLA                                 ; rotate A bit 4 into carry
0689   02BC CB 1E           RR (HL)                             ; rotate carry back into character
0690   02BE             
0691   02BE             ; DISPLAY-2
0692   02BE CD 3D 03        CALL SUB_033D                       ; KEYBOARD - scan keyboard and start VSYNC
0693   02C1 ED 4B 25 40     LD BC,($4025)                       ; get LAST_K
0694   02C5 22 25 40        LD ($4025),HL                       ; update LAST_K
0695   02C8 78              LD A,B
0696   02C9 C6 02           ADD A,$02
0697   02CB ED 42           SBC HL,BC
0698   02CD 3A 27 40        LD A,($4027)                        ; Check DEBOUNCE
0699   02D0 B4              OR H
0700   02D1 B5              OR L
0701   02D2 58              LD E,B
0702   02D3 06 09           LD B,$09                            ; ZX81 used $0B
0703   02D5 21 3B 40        LD HL,$403B                         ; Get CDFLAG
0704   02D8 CB 86           RES 0,(HL)
0705   02DA 20 08           JR NZ,L_02E4
0706   02DC CB 7E           BIT 7,(HL)
0707   02DE CB C6           SET 0,(HL)
0708   02E0 C8              RET Z                               ; return if in FAST mode
0709   02E1 05              DEC B
0710   02E2 05              DEC B                               ; extra DEC B, ZX81 was NOP
0711   02E3 37              SCF
0712   02E4             
0713   02E4             ; NO-KEY
0714   02E4             L_02E4:
0715   02E4 CB 10           RL B                                ; Reordered from ZX81
0716   02E6             
0717   02E6             ; LOOP-B
0718   02E6             L_02E6:
0719   02E6 10 FE           DJNZ L_02E6
0720   02E8 21 27 40        LD HL,$4027
0721   02EB 46              LD B,(HL)                           ; Get DEBOUCE
0722   02EC 7B              LD A,E
0723   02ED FE FE           CP $FE
0724   02EF 9F              SBC A,A
0725   02F0 06 0F           LD B,$0F                            ; ZX81 has $1F
0726   02F2 B6              OR (HL)
0727   02F3 A0              AND B
0728   02F4 1F              RRA
0729   02F5 77              LD (HL),A
0730   02F6 29              ADD HL,HL
0731   02F7 23              INC HL
0732   02F8 D3 FF           OUT ($FF),A                         ; End VSYNC pulse
0733   02FA             
0734   02FA 21 7D C0        LD HL,$407D + $8000                 ; Hard coded DFILE location
0735   02FD CD 14 03        CALL SUB_0314
0736   0300             
