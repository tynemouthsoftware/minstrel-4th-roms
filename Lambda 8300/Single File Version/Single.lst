0509   01F2             
0510   01F2             ; table of error messages, used by function at $07E1
0511   01F2             L_01F2:
0512   01F2 34 30           .BYTE $34,$30                       ; FF = OK - OK
0513   01F4 33 2B           .BYTE $33,$2B                       ; 00 = NF - NEXT without FOR
0514   01F6 3A 3B           .BYTE $3A,$3B                       ; 01 = UV - Unidentified Variable
0515   01F8 27 38           .BYTE $27,$38                       ; 02 = BS - Bad Subscript
0516   01FA 34 32           .BYTE $34,$32                       ; 03 = OM - Out of Memory
0517   01FC 38 2B           .BYTE $38,$2B                       ; 04 = SF - Screen Full
0518   01FE 34 3B           .BYTE $34,$3B                       ; 05 = OV - OVerflow
0519   0200 37 2C           .BYTE $37,$2C                       ; 06 = RG - RETURN without GOSUB
0520   0202 2E 2E           .BYTE $2E,$2E                       ; 07 = II - Illegal INPUT
0521   0204 38 39           .BYTE $38,$39                       ; 08 = ST - STop
0522   0206 26 2C           .BYTE $26,$2C                       ; 09 = AG - invalid ArGument
0523   0208 2E 37           .BYTE $2E,$37                       ; 0A = IR - Integer out of Range
0524   020A 2E 2A           .BYTE $2E,$2A                       ; 0B = IE - Invalid Expression
0525   020C 27 30           .BYTE $27,$30                       ; 0C = BK - BreaK
0526   020E 33 26           .BYTE $33,$26                       ; 0D = NA - No program NAme
0527   0210 32 2B           .BYTE $32,$2B                       ; 0E = MF - Music Format incorrect
0528   0212             
