2769   0BB1             ; -------------------------------
2770   0BB1             ; THE 'SCROLL COMMAND' SUBROUTINE
2771   0BB1             ; -------------------------------
2772   0BB1             
2773   0BB1             ; scrolling is easy with a fully expanded DFILE
2774   0BB1             ; copy lines 2-24 to 1-23
2775   0BB1             
2776   0BB1             ; SCROLL
2777   0BB1             SUB_0BB1:
2778   0BB1 21 9F 40        LD HL,DFILE+$22                     ; Source, start of line 2
2779   0BB4 11 7E 40        LD DE,DFILE+1                       ; Destination, start of line 1
2780   0BB7 01 F6 02        LD BC,$02F6                         ; 23*33-1, 23 lines to copy
2781   0BBA ED B0           LDIR                                ; copy
2782   0BBC FD 46 22        LD B,(IY+$22)                       ; get DF.SZ - Size of editor part of screen
2783   0BBF 04              INC B                               ; increase by 1 row
2784   0BC0 18 10           JR L_0BD2                           ; routine B-LINES, clear the editor lines
2785   0BC2             
2786   0BC2             ; --------------------------
