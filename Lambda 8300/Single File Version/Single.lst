3808   0F94 30 B5           JR NC,L_0F4B                        ; to REPORT, Music Format incorrect
3809   0F96 57              LD D,A
3810   0F97 CD 3D 0F        CALL L_0F3D                         ; routine MUSIC-10
3811   0F9A 28 12           JR Z,L_0FAE                         ; to MUSIC-5
3812   0F9C CD 36 0F        CALL SUB_0F36                       ; routine MUSIC-9
3813   0F9F 38 04           JR C,L_0FA5
3814   0FA1 2B              DEC HL
3815   0FA2 03              INC BC
