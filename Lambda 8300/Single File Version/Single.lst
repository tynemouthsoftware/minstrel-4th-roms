1176   0481             SUB_0481:
1177   0481 CD 70 03        CALL SUB_0370                       ; Set FAST mode
1178   0484 ED 4B 04 40     LD BC,($4004)                       ; RAMTOP top of detected / protected RAM
1179   0488 0B              DEC BC
1180   0489             
1181   0489             ; -----------------------
1182   0489             ; THE 'RAM CHECK' ROUTINE
1183   0489             ; -----------------------
1184   0489             
1185   0489             ; RAM-CHECK
1186   0489             L_0489:
1187   0489 60              LD H,B                              ; HL = BC = last byte to test
1188   048A 69              LD L,C
1189   048B 3E 3F           LD A,$3F                            ; stop point, check RAM down to $4000
1190   048D             
1191   048D             ; RAM-FILL
1192   048D             L_048D:
1193   048D 36 02           LD (HL),$02                         ; write 2 to every address in RAM.
1194   048F 2B              DEC HL
1195   0490 BC              CP H                                ; stop when H=A=$3F
1196   0491 20 FA           JR NZ,L_048D
1197   0493             
1198   0493             ; RAM-READ
1199   0493             L_0493:
1200   0493 A7              AND A                               ; reset carry flag
1201   0494 ED 42           SBC HL,BC                           ; Compare HL and BC
1202   0496 09              ADD HL,BC                           ;
1203   0497 23              INC HL                              ; HL = 4000 - what was the point in all that?
1204   0498 30 06           JR NC,L_04A0                        ; if HL=BC, we're finished?
1205   049A 35              DEC (HL)                            ; Decrement RAM
1206   049B 28 03           JR Z,L_04A0                         ; Test if RAM was 1, but it would be picked up by the next test anyway?
1207   049D                                                     ; I wonder if this was original a test for mirrors? but it doesn't do that now
1208   049D 35              DEC (HL)                            ; Decrement RAM
1209   049E 28 F3           JR Z,L_0493                         ; It was 2 previously, zero now, good RAM, keep checking
1210   04A0             
