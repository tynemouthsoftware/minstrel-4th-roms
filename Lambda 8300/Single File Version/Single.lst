1213   04A0 22 04 40        LD ($4004),HL                       ; Set RAMTOP, top of usable RAM
1214   04A3             
1215   04A3             ; ----------------------------------
1216   04A3             ; THE 'DFILE INITIALIZATION' ROUTINE
1217   04A3             ; ----------------------------------
1218   04A3             
1219   04A3             ; INIT-DFILE
1220   04A3             L_04A3:
1221   04A3 21 97 43        LD HL,$4397                         ; Set VARS, starts of variable area
1222   04A6 22 10 40        LD ($4010),HL                       ; VARS = $4397 - fixed location after DFILE
1223   04A9 2B              DEC HL                              ; HL = 4396, start of program
1224   04AA 36 FF           LD (HL),$FF
1225   04AC             L_04AC:
1226   04AC 22 0C 40        LD ($400C),HL                       ; Set PRGRM
1227   04AF             
1228   04AF             ; CREATE-DFILE
1229   04AF 0E 19           LD C,$19                            ; 24 lines + 1 extra NL
1230   04B1 AF              XOR A                               ; A = 0 = Space
1231   04B2             
1232   04B2             ; NEXT-LINE
1233   04B2             L_04B2:
1234   04B2 2B              DEC HL
1235   04B3 36 76           LD (HL),$76                         ; start / end with newline / halt
1236   04B5 0D              DEC C                               ; line counter
1237   04B6 28 08           JR Z,L_04C0                         ; finished?
1238   04B8             
1239   04B8             ; FILL-LINE
1240   04B8 06 20           LD B,$20                            ; fill line with 32 spaces
1241   04BA             L_04BA:
1242   04BA 2B              DEC HL                              ; step backwards
1243   04BB 77              LD (HL),A                           ; write a space
1244   04BC 10 FC           DJNZ L_04BA                         ; loop until done
1245   04BE 18 F2           JR L_04B2                           ; back for more
1246   04C0             
1247   04C0             ; ----------------------------
1248   04C0             ; THE 'INITIALIZATION' ROUTINE
1249   04C0             ; ----------------------------
1250   04C0             
1251   04C0             ; INITIAL
1252   04C0             L_04C0:
1253   04C0 2A 04 40        LD HL,($4004)                       ; Get RAMTOP
1254   04C3 2B              DEC HL                              ; Move to last system byte
1255   04C4 36 3E           LD (HL),$3E                         ; Set GOSUB end marker
1256   04C6 2B              DEC HL                              ; Move down again
1257   04C7 F9              LD SP,HL                            ; Set stack here
1258   04C8 2B              DEC HL                              ; Move to first location in stack
1259   04C9 2B              DEC HL                              ;
1260   04CA 22 02 40        LD ($4002),HL                       ; Set error stack pointer ERR_SP
1261   04CD                                                     ; I register is setup here on ZX81, not used on the Lambda,
1262   04CD                                                     ; The character ROM is inside the ULA
1263   04CD ED 56           IM 1                                ; Z80 interrupt mode 1
1264   04CF FD 21 00 40     LD IY,$4000                         ; Set IY to start of SYS VARS to make access easier
1265   04D3 FD 36 3B 40     LD (IY+$3B),$40                     ; CDFLAG - compute and display mode requested
1266   04D7 FD 36 21 19     LD (IY+$21),$19                     ; Set TEMPO to 25 (25*3.94ms = ~ 100ms)
1267   04DB AF              XOR A                               ; Clear more flags
1268   04DC 32 19 40        LD ($4019),A                        ; X_PTR_lo = 0
1269   04DF 32 2D 40        LD ($402D),A                        ; FLAGX = 0
1270   04E2 32 01 40        LD ($4001),A                        ; FLAGS = 0
1271   04E5 32 7C 40        LD ($407C),A                        ; SPARE3 = 0
1272   04E8 3D              DEC A                               ; A now $FF
1273   04E9 32 35 40        LD ($4035),A                        ; FRAMES_lo = $FF
1274   04EC CD 92 16        CALL SUB_1692                       ; CLEAR
1275   04EF CD 50 04        CALL SUB_0450                       ; MAKE-NOISE
