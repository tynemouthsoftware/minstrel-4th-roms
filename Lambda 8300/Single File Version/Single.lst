3758   0F4D             ; THE 'MUSIC' COMMAND ROUTINE
3759   0F4D             ; ---------------------------
3760   0F4D             
3761   0F4D             ; MUSIC
3762   0F4D             SUB_0F4D:
3763   0F4D CD 4A 11        CALL SUB_114A                       ; routine SCANNING
3764   0F50 FD CB 01 76     BIT 6,(IY+$01)                      ; check FLAGS - 0 = string or 1 = numeric result
3765   0F54 20 C1           JR NZ,L_0F17                        ; to REPORT-C - Invalid Expression
3766   0F56 CD 9A 0E        CALL SUB_0E9A                       ; routine CHECK-END
3767   0F59 CD ED 15        CALL SUB_15ED                       ; routine STK-FETCH
3768   0F5C EB              EX DE,HL                            ; DE now start address, HL string length
3769   0F5D CD 70 03        CALL SUB_0370                       ; routine SET-FAST
3770   0F60             
3771   0F60             ; MUSIC-1
3772   0F60             L_0F60:
3773   0F60 CD 3D 0F        CALL L_0F3D                         ; routine MUSIC-10 (get next character)
3774   0F63 CA 85 02        JP Z,SUB_0285                       ; check in FAST mode
3775   0F66 FE 1B           CP $1B                              ; is character '"'
3776   0F68 1E 01           LD E,$01
3777   0F6A 28 22           JR Z,L_0F8E                         ; to MUSIC-2 if it is
3778   0F6C 07              RLCA                                ; character x2
3779   0F6D FE 5A           CP $5A                              ; Before the rotate, A would have been $2D, 'H', so checking A-G
3780   0F6F 30 DA           JR NC,L_0F4B                        ; to REPORT, Music Format incorrect
3781   0F71 D6 4C           SUB $4C
3782   0F73 38 D6           JR C,L_0F4B                         ; to REPORT, Music Format incorrect
3783   0F75             
3784   0F75             ; get note
3785   0F75 E5              PUSH HL
3786   0F76 16 00           LD D,$00
3787   0F78 5F              LD E,A
3788   0F79 21 28 0F        LD HL,L_0F28                        ; address of MUSIC-TABLE
3789   0F7C 19              ADD HL,DE                           ; offset by 2x letter - 4C
3790   0F7D 5E              LD E,(HL)                           ; get note
3791   0F7E E1              POP HL
3792   0F7F             
3793   0F7F CD 47 0F        CALL SUB_0F47                       ; routine MUSIC-11
3794   0F82 FE 13           CP $13                              ; is character '<'
3795   0F84 28 08           JR Z,L_0F8E                         ; to MUSIC-2 if it is
3796   0F86 CB 3B           SRL E                               ; down an octave
3797   0F88 FE 12           CP $12                              ; is character '>'
3798   0F8A 20 05           JR NZ,L_0F91                        ; to MUSIC-3 if it isn't
3799   0F8C CB 3B           SRL E                               ; down an octave
3800   0F8E             
3801   0F8E             ; MUSIC-2
