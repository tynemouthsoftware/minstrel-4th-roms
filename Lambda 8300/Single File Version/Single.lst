2677   0B6A             SUB_0B6A:
2678   0B6A E5              PUSH HL
2679   0B6B 2A 0C 40        LD HL,($400C)                       ; PRGRM, start of user program
2680   0B6E 54              LD D,H
2681   0B6F 5D              LD E,L
2682   0B70             
2683   0B70             ; NEXT-TEST
2684   0B70             L_0B70:
2685   0B70 C1              POP BC
2686   0B71 CD 7C 0B        CALL SUB_0B7C
2687   0B74 D0              RET NC
2688   0B75 C5              PUSH BC
2689   0B76 CD 84 0B        CALL SUB_0B84
2690   0B79 EB              EX DE,HL
2691   0B7A 18 F4           JR L_0B70
