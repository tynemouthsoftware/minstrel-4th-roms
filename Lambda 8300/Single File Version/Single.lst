1008   03E7 17              RLA                                 ; bit 7->Carry
1009   03E8 38 28           JR C,L_0412                         ; Forward to GET-BIT if there is data
1010   03EA 10 F1           DJNZ L_03DD                         ; Loop back and keep checking
1011   03EC F1              POP AF                              ; Drop return address
