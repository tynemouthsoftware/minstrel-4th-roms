0809   033D             ; ----------------------------------
0810   033D             ; THE 'KEYBOARD SCANNING' SUBROUTINE
0811   033D             ; ----------------------------------
0812   033D             
0813   033D             ; KEYBOARD
0814   033D             .ORG $033D
0815   033D             SUB_033D:
0816   033D 21 FF FF        LD HL,$FFFF
0817   0340 01 FE FE        LD BC,$FEFE
0818   0343 ED 78           IN A,(C)                            ; Read port $FE, starts VSync pulse
0819   0345 F6 01           OR $01                              ; Ignore shift
0820   0347             
0821   0347             ; EACH-LINE
0822   0347             L_0347:
0823   0347 F6 E0           OR $E0
0824   0349 57              LD D,A
0825   034A 2F              CPL
0826   034B FE 01           CP $01
0827   034D 9F              SBC A,A
0828   034E B0              OR B
0829   034F A5              AND L
0830   0350 6F              LD L,A
0831   0351 7C              LD A,H
0832   0352 A2              AND D
0833   0353 67              LD H,A
0834   0354 CB 00           RLC B
0835   0356 ED 78           IN A,(C)
0836   0358 38 ED           JR C,L_0347
0837   035A 1F              RRA
0838   035B CB 14           RL H
0839   035D             
0840   035D             ; GET_REGION
0841   035D 3E FF           LD A,$FF                            ; Read port $7E
0842   035F DB 7E           IN A,($7E)                          ; Will return the same as $FE unless there is something different in the Lambda
0843   0361 1F              RRA                                 ; Bit 7 => carry (Bit 7 that is the tape input???)
0844   0362 1F              RRA                                 ; Rotate bit 6 (PAL/NTSC) to carry
0845   0363 9F              SBC A,A                             ; A = $FF (PAL) or $00 (NTSC)
0846   0364 E6 18           AND $18                             ; A = $18       or $00
0847   0366 C6 1F           ADD A,$1F                           ; A = $37       or $1F
0848   0368 32 28 40        LD ($4028),A                        ; Save this as MARGIN
0849   036B C9              RET
0850   036C             
