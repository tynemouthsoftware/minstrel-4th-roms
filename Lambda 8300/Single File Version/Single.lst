1112   0450             
1113   0450             ; MAKE-NOISE
1114   0450             SUB_0450:
1115   0450 1E 20           LD E,$20                            ; note = 32500/32 = 1.02KHz
1116   0452 01 00 18        LD BC,$1800                         ; duration = 6144/65 = 94ms
1117   0455 18 09           JR L_0460                           ; Routine PLAY-NOTE
1118   0457             
