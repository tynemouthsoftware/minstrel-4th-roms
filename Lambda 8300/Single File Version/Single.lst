8023   1FB6 04              .BYTE $04                           ; multiply      x, x*x.
8024   1FB7 A1              .BYTE $A1                           ; stk-one       x, x*x, 1.
8025   1FB8 03              .BYTE $03                           ; subtract      x, x*x-1.
8026   1FB9 18              .BYTE $18                           ; negate        x, 1-x*x.
8027   1FBA 25              .BYTE $25                           ; sqr           x, sqr(1-x*x) = y.
8028   1FBB A1              .BYTE $A1                           ; stk-one       x, y, 1.
8029   1FBC 0F              .BYTE $0F                           ; addition      x, y+1.
8030   1FBD 05              .BYTE $05                           ; division      x/y+1.
8031   1FBE 21              .BYTE $21                           ; atn           a/2     (half the angle)
8032   1FBF 2D              .BYTE $2D                           ; duplicate     a/2, a/2.
8033   1FC0 0F              .BYTE $0F                           ; addition      a.
