3840   0FB8 CD 63 04        CALL L_0463                         ; routine PLAY-NOTE-2
3841   0FBB 25              DEC H
3842   0FBC 20 F9           JR NZ,L_0FB7                        ; loop back to MUSIC-6
3843   0FBE 06 05           LD B,$05
