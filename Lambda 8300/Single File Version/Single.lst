4193   1117 E6 80           AND $80
4194   1119 57              LD D,A                              ; D = old bit 7 of B
4195   111A CB F8           SET 7,B                             ; Set bit 7, indicatin PAUSE mode
4196   111C ED 43 34 40     LD ($4034),BC                       ; Alternate value in frame counter
4197   1120             
