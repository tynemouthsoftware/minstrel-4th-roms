1126   045A C5              PUSH BC
1127   045B CD 83 10        CALL SUB_1083                       ; routine FIND-SHORT => A
1128   045E C1              POP BC
1129   045F 5F              LD E,A                              ; INT => E
1130   0460             
1131   0460             ; PLAY-NOTE
1132   0460             ; E = note, defined as 32500Hz/E, so (0=256=>127Hz) to (1=>32.5KHz)
1133   0460             ; BC = duration, defined as BC/65ms, so (1=>15ms) to (0=65536=>1 second)
1134   0460             ; Appox 4 times slower in SLOW mode
1135   0460             L_0460:
1136   0460 C3 81 2C        JP PLAY_NOTE                        ; replacement play-note function
1137   0463             L_0463:    
1138   0463 C3 85 2C        JP PLAY_NOTE_2                      ; alternate entry point for MUSIC
